---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	hideFooter?: boolean;
	mainClass?: string;
	bodyClass?: string;
}

const { title = 'Nutrivia', hideFooter = false, mainClass = '', bodyClass = '' } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo.svg" />
		<link rel="icon" href="/logo.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class={`min-h-screen bg-white text-slate-700 antialiased ${bodyClass}`.trim()}>
		<div class="flex min-h-screen flex-col">
			<Header />
			<main class={`flex-1 ${mainClass}`.trim()}>
				<slot />
			</main>
			{!hideFooter && <Footer />}
		</div>
	</body>
</html>
