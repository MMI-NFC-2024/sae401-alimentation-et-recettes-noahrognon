---
interface Props {
	name:
		| 'home'
		| 'dashboard'
		| 'recipes'
		| 'planner'
		| 'progress'
		| 'community'
		| 'shopping'
		| 'foods'
		| 'diets'
		| 'assistant';
	active?: boolean;
}

const { name, active = false } = Astro.props;
const stroke = active ? '#0B8C5F' : '#4A5E7C';
const iconClass = 'h-[22px] w-[22px] shrink-0';
---

{
	name === 'home' && (
		<svg viewBox="0 0 24 24" aria-hidden="true" class={iconClass}>
			<path d="M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM14 14h6v6h-6z" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	)
}
{
	name === 'dashboard' && (
		<svg viewBox="0 0 24 24" aria-hidden="true" class={iconClass}>
			<path d="M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM14 14h6v6h-6z" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	)
}
{
	name === 'recipes' && (
		<svg viewBox="0 0 24 24" aria-hidden="true" class={iconClass}>
			<path d="M8 10V8a4 4 0 0 1 8 0v2" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
			<path d="M7 10h10a2 2 0 0 1 2 2v4.5A2.5 2.5 0 0 1 16.5 19h-9A2.5 2.5 0 0 1 5 16.5V12a2 2 0 0 1 2-2Z" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	)
}
{
	name === 'planner' && (
		<svg viewBox="0 0 24 24" aria-hidden="true" class={iconClass}>
			<path d="M7 3v3M17 3v3M4 9h16" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
			<rect x="4" y="5" width="16" height="15" rx="2.5" fill="none" stroke={stroke} stroke-width="1.8"></rect>
		</svg>
	)
}
{
	name === 'progress' && (
		<svg viewBox="0 0 24 24" aria-hidden="true" class={iconClass}>
			<path d="M4 16l5-5 4 4 7-7" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
			<path d="M16 8h4v4" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	)
}
{
	name === 'community' && (
		<svg viewBox="0 0 24 24" aria-hidden="true" class={iconClass}>
			<path d="M16.5 19v-1.2A3.8 3.8 0 0 0 12.7 14H7.8A3.8 3.8 0 0 0 4 17.8V19" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
			<path d="M10.2 10.2A3.2 3.2 0 1 0 10.2 3.8a3.2 3.2 0 0 0 0 6.4ZM20 19v-1.2a3.8 3.8 0 0 0-2.7-3.63M15.3 4a3.2 3.2 0 0 1 0 6.2" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	)
}
{
	name === 'shopping' && (
		<svg viewBox="0 0 24 24" aria-hidden="true" class={iconClass}>
			<circle cx="9" cy="19" r="1.3" fill={stroke}></circle>
			<circle cx="17" cy="19" r="1.3" fill={stroke}></circle>
			<path d="M3 4h2l2.3 10.2a1 1 0 0 0 1 .8h8.9a1 1 0 0 0 1-.76L20 7H6" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	)
}
{
	name === 'foods' && (
		<svg viewBox="0 0 24 24" aria-hidden="true" class={iconClass}>
			<path d="M12 20s-6-3.6-6-9.1A4.1 4.1 0 0 1 12 8a4.1 4.1 0 0 1 6 2.9C18 16.4 12 20 12 20Z" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
			<path d="M12 8c0-2.2 1.4-4 3.2-4" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	)
}
{
	name === 'diets' && (
		<svg viewBox="0 0 24 24" aria-hidden="true" class={iconClass}>
			<path d="M12 20s-6-3.6-6-9.1A4.1 4.1 0 0 1 12 8a4.1 4.1 0 0 1 6 2.9C18 16.4 12 20 12 20Z" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
			<path d="M9 6c.2-1.4 1.1-2.7 2.7-3.2" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	)
}
{
	name === 'assistant' && (
		<svg viewBox="0 0 24 24" aria-hidden="true" class={iconClass}>
			<path d="M10.3 13.7a2.84 2.84 0 0 0-2-2l-2.7-.7a.57.57 0 0 1 0-1.1l2.7-.7a2.84 2.84 0 0 0 2-2l.7-2.7a.57.57 0 0 1 1.1 0l.7 2.7a2.84 2.84 0 0 0 2 2l2.7.7a.57.57 0 0 1 0 1.1l-2.7.7a2.84 2.84 0 0 0-2 2l-.7 2.7a.57.57 0 0 1-1.1 0Z" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
			<path d="M18.5 4.5v3M20 6h-3M5 17v1.5M5.75 17.75h-1.5" fill="none" stroke={stroke} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	)
}
