---
import Layout from '../../layouts/Layout.astro';

const slug = Astro.params.slug ?? '';
---

<Layout
	title="Rendez-vous avec un professionnel de la nutrition - Nutrivia"
	description="Consultez le profil d’un professionnel de la nutrition, ses spécialités, ses modes de consultation, ses disponibilités et réservez un rendez-vous."
>
	<section class="bg-[radial-gradient(circle_at_top_left,_rgba(205,248,224,0.75),_transparent_42%),linear-gradient(180deg,#fbffff_0%,#f5fbff_100%)]">
		<div class="mx-auto max-w-[1180px] px-4 py-8 md:px-6 md:py-10">
			<a href="/professionnels" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 transition hover:text-[#08b37d]">
				<span aria-hidden="true">←</span>
				Retour aux professionnels
			</a>

			<div id="professional-error" class="mt-6 hidden rounded-2xl border border-[#ffd8d8] bg-[#fff6f6] px-4 py-3 text-sm font-medium text-[#c24141]"></div>
			<div id="professional-loading" class="mt-8 text-sm font-medium text-slate-500">Chargement du profil...</div>

			<div id="professional-shell" class="mt-8 hidden grid gap-6 lg:grid-cols-[minmax(0,1.15fr)_360px]">
				<div class="space-y-6">
					<article class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7">
						<div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
							<div class="flex gap-4">
								<div id="professional-avatar" class="flex h-20 w-20 shrink-0 items-center justify-center rounded-[26px] bg-[linear-gradient(135deg,#08b37d_0%,#5cd6b5_100%)] text-2xl font-semibold text-white"></div>
								<div class="min-w-0">
									<h1 id="professional-name" class="text-3xl font-semibold tracking-[-0.03em] text-slate-900"></h1>
									<p id="professional-speciality" class="mt-2 text-base font-semibold text-[#08b37d]"></p>
									<p id="professional-location" class="mt-2 text-sm text-slate-500"></p>
								</div>
							</div>
							<div class="rounded-[22px] bg-slate-50 px-5 py-4 text-right">
								<p class="text-xs font-medium uppercase tracking-[0.14em] text-slate-400">Consultation</p>
								<p id="professional-price" class="mt-2 text-2xl font-semibold text-slate-900"></p>
							</div>
						</div>

						<p id="professional-description" class="mt-6 text-base leading-7 text-slate-600"></p>

						<div class="mt-6 grid gap-4 md:grid-cols-3">
							<div class="rounded-[22px] bg-slate-50 p-4">
								<p class="text-xs font-medium uppercase tracking-[0.14em] text-slate-400">Expérience</p>
								<p id="professional-experience" class="mt-2 text-lg font-semibold text-slate-800"></p>
							</div>
							<div class="rounded-[22px] bg-slate-50 p-4 md:col-span-2">
								<p class="text-xs font-medium uppercase tracking-[0.14em] text-slate-400">Modes de consultation</p>
								<div id="professional-modes" class="mt-3 flex flex-wrap gap-2"></div>
							</div>
						</div>
					</article>

					<article class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7">
						<div class="flex items-center justify-between gap-4">
							<div>
								<h2 class="text-2xl font-semibold text-slate-900">Créneaux disponibles</h2>
								<p class="mt-2 text-sm text-slate-500">Choisissez une date et un horaire disponibles pour réserver votre consultation.</p>
							</div>
							<span id="availabilities-count" class="rounded-full bg-[#d8f7e1] px-3 py-1 text-sm font-semibold text-[#0a9a68]"></span>
						</div>
						<div id="availabilities-grid" class="mt-6 grid gap-3 md:grid-cols-2"></div>
					</article>
				</div>

				<aside class="space-y-6">
					<article class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-6">
						<h2 class="text-xl font-semibold text-slate-900">Réserver un rendez-vous</h2>
						<p class="mt-2 text-sm leading-6 text-slate-500">
							Sélectionnez un créneau, ajoutez un motif si besoin, puis confirmez votre réservation.
						</p>

						<div class="mt-5 rounded-[20px] bg-slate-50 p-4">
							<p class="text-xs font-medium uppercase tracking-[0.14em] text-slate-400">Créneau sélectionné</p>
							<p id="booking-selected" class="mt-2 text-sm font-semibold text-slate-700">Aucun créneau sélectionné</p>
						</div>

						<label class="mt-5 block">
							<span class="mb-2 block text-sm font-semibold text-slate-700">Motif du rendez-vous</span>
							<textarea
								id="booking-motif"
								rows="5"
								placeholder="Ex : perte de poids, rééquilibrage alimentaire, préparation sportive..."
								class="w-full rounded-[20px] border border-[#cad8e7] px-4 py-3 text-sm text-slate-700 outline-none transition placeholder:text-slate-400 focus:border-[#08b37d]"
							></textarea>
						</label>

						<p id="booking-feedback" class="mt-4 hidden rounded-2xl px-4 py-3 text-sm font-medium"></p>

						<button
							id="booking-submit"
							type="button"
							class="mt-5 inline-flex w-full items-center justify-center rounded-[18px] bg-[#08b37d] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#079765] disabled:cursor-not-allowed disabled:bg-slate-200 disabled:text-slate-500"
							disabled
						>
							Confirmer ce rendez-vous
						</button>
					</article>

					<article class="rounded-[28px] border border-[#d8e5f1] bg-[linear-gradient(135deg,#0aa975_0%,#3fd0b1_100%)] p-5 text-white shadow-[0_24px_70px_rgba(8,179,125,0.28)] md:p-6">
						<p class="text-sm font-semibold uppercase tracking-[0.18em] text-white/75">Accompagnement</p>
						<h3 class="mt-4 text-2xl font-semibold tracking-[-0.03em]">Préparez votre rendez-vous</h3>
						<p class="mt-3 text-sm leading-6 text-white/90">
							Ajoutez un motif précis pour aider le professionnel à préparer la consultation selon votre objectif nutritionnel.
						</p>
						<ul class="mt-5 space-y-2 text-sm text-white/85">
							<li>• Perte ou prise de poids</li>
							<li>• Organisation des repas</li>
							<li>• Nutrition sportive</li>
							<li>• Rééquilibrage alimentaire</li>
						</ul>
					</article>
				</aside>
			</div>
		</div>
	</section>
</Layout>

<script define:vars={{ slug }}>
	const authKey = 'nutrivia_auth';
	const shell = document.querySelector('#professional-shell');
	const loading = document.querySelector('#professional-loading');
	const errorBox = document.querySelector('#professional-error');
	const countBox = document.querySelector('#availabilities-count');
	const availabilitiesGrid = document.querySelector('#availabilities-grid');
	const submitButton = document.querySelector('#booking-submit');
	const feedbackBox = document.querySelector('#booking-feedback');
	const selectedLabel = document.querySelector('#booking-selected');
	const motifField = document.querySelector('#booking-motif');

	let professionalDetail = null;
	let selectedAvailabilityId = '';

	function escapeHtml(value) {
		return String(value ?? '')
			.replaceAll('&', '&amp;')
			.replaceAll('<', '&lt;')
			.replaceAll('>', '&gt;')
			.replaceAll('"', '&quot;')
			.replaceAll("'", '&#039;');
	}

	function readStoredAuth() {
		try {
			return JSON.parse(localStorage.getItem(authKey) || 'null');
		} catch {
			return null;
		}
	}

	function saveAuth(payload) {
		if (!payload?.token) return;
		localStorage.setItem(authKey, JSON.stringify(payload));
	}

	function clearAuth() {
		localStorage.removeItem(authKey);
	}

	function showError(message = '') {
		if (!errorBox) return;
		errorBox.textContent = message;
		errorBox.classList.toggle('hidden', !message);
	}

	function showBookingFeedback(message = '', type = 'error') {
		if (!feedbackBox) return;
		if (!message) {
			feedbackBox.className = 'mt-4 hidden rounded-2xl px-4 py-3 text-sm font-medium';
			feedbackBox.textContent = '';
			return;
		}

		feedbackBox.className =
			type === 'success'
				? 'mt-4 rounded-2xl bg-[#ecfdf4] px-4 py-3 text-sm font-medium text-[#0a9a68]'
				: 'mt-4 rounded-2xl bg-[#fff6f6] px-4 py-3 text-sm font-medium text-[#c24141]';
		feedbackBox.textContent = message;
	}

	function renderDetail(payload) {
		professionalDetail = payload;
		const professional = payload.professional || {};
		document.querySelector('#professional-avatar').textContent = professional.initials || 'PR';
		document.querySelector('#professional-name').textContent = professional.name || 'Professionnel';
		document.querySelector('#professional-speciality').textContent = professional.specialityLabel || '';
		document.querySelector('#professional-location').textContent = professional.city || 'Consultation en ligne';
		document.querySelector('#professional-price').textContent = `${professional.price || 0} €`;
		document.querySelector('#professional-description').textContent = professional.description || '';
		document.querySelector('#professional-experience').textContent = `${professional.experienceYears || 0} ans`;
		document.querySelector('#professional-modes').innerHTML = (professional.consultationModes || [])
			.map(
				(mode) =>
					`<span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600 shadow-[inset_0_0_0_1px_#d8e5f1]">${escapeHtml(mode)}</span>`,
			)
			.join('');

		const availabilities = payload.availabilities || [];
		countBox.textContent = `${availabilities.length} créneau${availabilities.length > 1 ? 'x' : ''}`;
		availabilitiesGrid.innerHTML = availabilities.length
			? availabilities
					.map(
						(item) => `
							<button
								type="button"
								data-availability-id="${escapeHtml(item.id)}"
								class="availability-card flex flex-col rounded-[22px] border border-[#d8e5f1] bg-white px-4 py-4 text-left transition hover:border-[#08b37d] hover:bg-[#f5fff9]"
							>
								<span class="text-xs font-medium uppercase tracking-[0.14em] text-slate-400">${escapeHtml(item.dateLabel)}</span>
								<span class="mt-2 text-lg font-semibold text-slate-900">${escapeHtml(item.timeLabel)}</span>
							</button>
						`,
					)
					.join('')
			: `<div class="rounded-[24px] border border-dashed border-[#cad8e7] bg-slate-50 p-6 text-sm text-slate-500 md:col-span-2">Aucun créneau n'est disponible pour le moment.</div>`;

		Array.from(availabilitiesGrid.querySelectorAll('[data-availability-id]')).forEach((button) => {
			button.addEventListener('click', () => {
				selectedAvailabilityId = button.getAttribute('data-availability-id') || '';
				Array.from(availabilitiesGrid.querySelectorAll('[data-availability-id]')).forEach((node) => {
					node.classList.remove('border-[#08b37d]', 'bg-[#f5fff9]');
				});
				button.classList.add('border-[#08b37d]', 'bg-[#f5fff9]');
				const selectedSlot = (professionalDetail.availabilities || []).find((item) => item.id === selectedAvailabilityId);
				selectedLabel.textContent = selectedSlot ? `${selectedSlot.dateLabel} · ${selectedSlot.timeLabel}` : 'Aucun créneau sélectionné';
				submitButton.disabled = !selectedAvailabilityId;
				showBookingFeedback('');
			});
		});
	}

	async function loadProfessional() {
		showError('');
		try {
			const response = await fetch(`/app-api/professionals/${encodeURIComponent(slug)}`);
			const payload = await response.json();
			if (!response.ok) {
				throw new Error(payload.message || 'Impossible de charger ce professionnel.');
			}

			renderDetail(payload);
			shell.classList.remove('hidden');
		} catch (error) {
			showError(error instanceof Error ? error.message : 'Impossible de charger ce professionnel.');
		} finally {
			loading.classList.add('hidden');
		}
	}

	async function bookAppointment() {
		if (!selectedAvailabilityId) return;
		const auth = readStoredAuth();
		if (!auth?.token) {
			window.location.href = `/auth/login?redirect=${encodeURIComponent(window.location.pathname)}`;
			return;
		}

		submitButton.disabled = true;
		showBookingFeedback('');

		try {
			const response = await fetch(`/app-api/professionals/${encodeURIComponent(slug)}`, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					Authorization: `Bearer ${auth.token}`,
				},
				body: JSON.stringify({
					availabilityId: selectedAvailabilityId,
					motif: motifField.value.trim(),
				}),
			});

			const payload = await response.json();
			if (!response.ok) {
				if (response.status === 401) {
					clearAuth();
					window.location.href = `/auth/login?redirect=${encodeURIComponent(window.location.pathname)}`;
					return;
				}
				throw new Error(payload.message || 'Impossible de réserver ce rendez-vous.');
			}

			if (payload.token) {
				saveAuth({ ...auth, token: payload.token });
			}

			const query = new URLSearchParams({
				pro: payload.appointment.professionalName || '',
				date: payload.appointment.dateLabel || '',
				time: payload.appointment.timeLabel || '',
			});
			window.location.href = `/rendez-vous/confirmation?${query.toString()}`;
		} catch (error) {
			showBookingFeedback(error instanceof Error ? error.message : 'Impossible de réserver ce rendez-vous.');
			submitButton.disabled = false;
		}
	}

	submitButton?.addEventListener('click', bookAppointment);
	loadProfessional();
</script>
