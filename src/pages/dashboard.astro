---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tableau de bord - Nutrivia">
	<section class="bg-[radial-gradient(circle_at_left_top,rgba(214,247,223,0.76),transparent_28%),radial-gradient(circle_at_right_bottom,rgba(218,236,255,0.72),transparent_34%),linear-gradient(180deg,#f7fdf9_0%,#fbfdff_66%,#f4f9ff_100%)] py-8 lg:py-10">
		<div class="mx-auto max-w-[1180px] px-4 md:px-6">
			<div class="mx-auto max-w-[1080px]">
				<div class="mb-7">
					<h1 id="dashboard-greeting" class="text-[2.2rem] font-semibold tracking-[-0.04em] text-[#16223c]">Bonjour</h1>
					<p class="mt-2 text-[1.05rem] text-slate-500">Bienvenue sur votre tableau de bord nutritionnel</p>
				</div>

				<p id="dashboard-error" class="mb-5 hidden rounded-2xl bg-red-50 px-4 py-3 text-sm text-red-600"></p>

				<a href="#" class="mb-5 block overflow-hidden rounded-[26px] bg-[linear-gradient(135deg,#08996d_0%,#08b37d_54%,#16c39c_100%)] px-5 py-5 text-white shadow-[0_24px_54px_rgba(8,179,125,0.24)] sm:px-6 sm:py-6">
					<div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
						<div>
							<div class="inline-flex items-center gap-2 rounded-full bg-white/15 px-3 py-1 text-[0.76rem] font-semibold uppercase tracking-[0.14em] text-white">
								<svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" aria-hidden="true"><path d="M12 3l2.5 5 5.5.8-4 3.9.9 5.5-4.9-2.6-4.9 2.6.9-5.5-4-3.9 5.5-.8L12 3Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path></svg>
								Offre premium
							</div>
							<h2 class="mt-4 text-[2rem] font-semibold tracking-[-0.04em]">Passez à NutriPlan Pro</h2>
							<p class="mt-2 max-w-[42rem] text-[1rem] leading-7 text-white/85">Plans personnalisés IA, analyses avancées, coaching nutrition et plus encore</p>
							<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
								<span class="inline-flex min-h-[44px] items-center justify-center rounded-[14px] bg-white px-4 py-2.5 text-[0.95rem] font-semibold text-[#0b8c5f]">Essayer gratuitement</span>
								<span class="text-[0.94rem] text-white/80">7 jours d’essai gratuit</span>
							</div>
						</div>
						<div class="hidden lg:flex h-[94px] w-[94px] items-center justify-center rounded-[26px] bg-white/10">
							<svg viewBox="0 0 24 24" class="h-12 w-12" fill="none" aria-hidden="true"><path d="M8 21h8M12 17v4M7 4h10v3a4 4 0 0 0 4 4v1a7 7 0 0 1-6 6.93V20H9v-1.07A7 7 0 0 1 3 12v-1a4 4 0 0 0 4-4V4Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>
						</div>
					</div>
				</a>

				<div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_300px]">
					<div class="grid content-start gap-5">
						<section class="rounded-[24px] border border-[#d8e2ee] bg-white px-5 py-5 shadow-[0_16px_38px_rgba(71,104,145,0.08)] sm:px-6">
							<div class="flex flex-wrap items-center justify-between gap-3">
								<h2 class="text-[1.4rem] font-semibold text-[#16223c]">Objectif du jour</h2>
								<p id="dashboard-date" class="text-[0.95rem] text-slate-400">-</p>
							</div>
							<div class="mt-6 grid gap-6 lg:grid-cols-[280px_minmax(0,1fr)] lg:items-center">
								<div class="flex flex-col items-center">
									<div id="dashboard-ring" class="flex h-[176px] w-[176px] items-center justify-center rounded-full bg-[conic-gradient(#08b37d_0deg,#08b37d_180deg,#e6edf6_180deg,#e6edf6_360deg)] p-3">
										<div class="flex h-full w-full flex-col items-center justify-center rounded-full bg-white text-center">
											<svg viewBox="0 0 24 24" class="h-6 w-6 text-[#08b37d]" fill="none" aria-hidden="true"><path d="M12 3c-1.5 3-4 5.2-4 9a4 4 0 1 0 8 0c0-1.6-.5-3-1.4-4.3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>
											<p id="dashboard-calories-consumed" class="mt-3 text-[2.25rem] font-semibold leading-none text-[#16223c]">0</p>
											<p id="dashboard-calories-target" class="mt-2 text-[0.95rem] text-slate-500">sur 0 kcal</p>
											<p id="dashboard-calories-remaining" class="mt-1 text-[0.88rem] text-[#08b37d]">0 restantes</p>
										</div>
									</div>
								</div>
								<div class="grid gap-4">
									<div>
										<div class="mb-2 flex items-center justify-between text-[0.96rem] text-slate-500">
											<span>Protéines</span>
											<span id="dashboard-proteins-label">0 / 0 g</span>
										</div>
										<div class="h-3 overflow-hidden rounded-full bg-[#eef3fa]"><div id="dashboard-proteins-bar" class="h-full rounded-full bg-[#ef4444]" style="width:0%"></div></div>
									</div>
									<div>
										<div class="mb-2 flex items-center justify-between text-[0.96rem] text-slate-500">
											<span>Glucides</span>
											<span id="dashboard-carbs-label">0 / 0 g</span>
										</div>
										<div class="h-3 overflow-hidden rounded-full bg-[#eef3fa]"><div id="dashboard-carbs-bar" class="h-full rounded-full bg-[#f59e0b]" style="width:0%"></div></div>
									</div>
									<div>
										<div class="mb-2 flex items-center justify-between text-[0.96rem] text-slate-500">
											<span>Lipides</span>
											<span id="dashboard-fats-label">0 / 0 g</span>
										</div>
										<div class="h-3 overflow-hidden rounded-full bg-[#eef3fa]"><div id="dashboard-fats-bar" class="h-full rounded-full bg-[#84cc16]" style="width:0%"></div></div>
									</div>
								</div>
							</div>
						</section>

						<section class="overflow-hidden rounded-[24px] bg-[linear-gradient(180deg,#0ea57f_0%,#0b9875_100%)] px-5 py-5 text-white shadow-[0_22px_48px_rgba(8,179,125,0.26)] sm:px-6">
							<div class="flex flex-wrap items-start justify-between gap-4">
								<div>
									<div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-white/15">
										<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" aria-hidden="true"><path d="M6 12h4l2-6 2 12 2-6h2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>
									</div>
									<h2 id="dashboard-sport-title" class="mt-4 text-[1.35rem] font-semibold">Profil actif</h2>
									<p id="dashboard-sport-subtitle" class="mt-1 text-[0.96rem] text-white/80">-</p>
								</div>
								<div class="hidden text-white/10 lg:block">
									<svg viewBox="0 0 24 24" class="h-20 w-20" fill="none" aria-hidden="true"><path d="M7 7h2l2 2-4 4-2-2 2-2Zm10 10h-2l-2-2 4-4 2 2-2 2ZM9 11l6 6m0-10-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>
								</div>
							</div>
							<div class="mt-5 grid gap-3 sm:grid-cols-3">
								<div class="rounded-[18px] bg-white/10 px-4 py-4 text-center"><p id="dashboard-protein-kg" class="text-[2rem] font-semibold">0</p><p class="mt-1 text-[0.88rem] text-white/75">protéines/kg</p></div>
								<div class="rounded-[18px] bg-white/10 px-4 py-4 text-center"><p id="dashboard-calorie-adjustment" class="text-[2rem] font-semibold">-</p><p class="mt-1 text-[0.88rem] text-white/75">ajustement cible</p></div>
								<div class="rounded-[18px] bg-white/10 px-4 py-4 text-center"><p id="dashboard-water" class="text-[2rem] font-semibold">0L</p><p class="mt-1 text-[0.88rem] text-white/75">eau/jour</p></div>
							</div>
							<a href="/profile" class="mt-5 inline-flex min-h-[46px] w-full items-center justify-center rounded-[14px] bg-white px-5 py-3 text-[0.96rem] font-semibold text-[#0b8c5f]">Ajuster mon profil sportif</a>
						</section>

						<section class="rounded-[24px] border border-[#d8e2ee] bg-white px-5 py-5 shadow-[0_16px_38px_rgba(71,104,145,0.08)] sm:px-6">
							<div class="flex items-center justify-between gap-3">
								<h2 class="text-[1.4rem] font-semibold text-[#16223c]">Planning du jour</h2>
								<a href="/planificateur" class="text-[0.92rem] font-medium text-[#08b37d]">Modifier</a>
							</div>
							<div id="dashboard-day-planning" class="mt-5 grid gap-3"></div>
						</section>

						<section class="rounded-[24px] border border-[#d8e2ee] bg-white px-5 py-5 shadow-[0_16px_38px_rgba(71,104,145,0.08)] sm:px-6">
							<div class="flex items-center justify-between gap-3">
								<div>
									<h2 class="text-[1.4rem] font-semibold text-[#16223c]">Produits recommandés</h2>
									<p class="mt-1 text-[0.88rem] text-slate-400">Partenaires certifiés</p>
								</div>
								<span class="inline-flex rounded-full bg-[#e9fbf2] px-3 py-1 text-[0.76rem] font-medium text-[#0b8c5f]">Sponsorisé</span>
							</div>
							<div id="dashboard-products" class="mt-5 grid gap-3 md:grid-cols-2"></div>
						</section>

						<section class="rounded-[24px] border border-[#d8e2ee] bg-white px-5 py-5 shadow-[0_16px_38px_rgba(71,104,145,0.08)] sm:px-6">
							<div class="flex items-center justify-between gap-3">
								<h2 class="text-[1.4rem] font-semibold text-[#16223c]">Recettes recommandées</h2>
								<a href="/recettes" class="text-[0.92rem] font-medium text-[#08b37d]">Voir tout</a>
							</div>
							<div id="dashboard-recipes" class="mt-5 grid gap-4 sm:grid-cols-2 xl:grid-cols-3"></div>
						</section>
					</div>

					<div class="grid content-start gap-5">
						<section class="rounded-[24px] border border-[#d8e2ee] bg-white p-5 shadow-[0_16px_38px_rgba(71,104,145,0.08)]">
							<h2 class="text-[1.32rem] font-semibold text-[#16223c]">Actions rapides</h2>
							<div class="mt-5 grid gap-3">
								<a href="/planificateur" class="flex items-center gap-3 rounded-[18px] bg-[#e9fbf2] px-4 py-4 text-[0.96rem] font-medium text-[#16223c]"><span class="flex h-11 w-11 items-center justify-center rounded-[14px] bg-[#08b37d] text-white"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="none"><path d="M8 3v3M16 3v3M4 9h16M6 5h12a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span>Planifier mes repas</span></a>
								<a href="/liste-courses" class="flex items-center gap-3 rounded-[18px] bg-[#eef4ff] px-4 py-4 text-[0.96rem] font-medium text-[#16223c]"><span class="flex h-11 w-11 items-center justify-center rounded-[14px] bg-[#2d63ff] text-white"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="none"><path d="M6 6h15l-1.5 8h-11L6 6Zm0 0-1-2H3M9 19a1 1 0 1 1 0 2 1 1 0 0 1 0-2Zm9 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span>Liste de courses</span></a>
								<a href="/suivi" class="flex items-center gap-3 rounded-[18px] bg-[#f7efff] px-4 py-4 text-[0.96rem] font-medium text-[#16223c]"><span class="flex h-11 w-11 items-center justify-center rounded-[14px] bg-[#9333ea] text-white"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="none"><path d="M4 14h4l3-4 4 5 5-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span>Suivi alimentaire</span></a>
								<a href="/recettes" class="flex items-center gap-3 rounded-[18px] bg-[#fff3e9] px-4 py-4 text-[0.96rem] font-medium text-[#16223c]"><span class="flex h-11 w-11 items-center justify-center rounded-[14px] bg-[#f97316] text-white"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="none"><path d="M8 4h8M6 8h12M7 12h10M9 16h6M6 20h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path></svg></span><span>Parcourir les recettes</span></a>
							</div>
						</section>

						<section class="rounded-[24px] bg-[linear-gradient(180deg,#0ea57f_0%,#0b9875_100%)] px-5 py-5 text-white shadow-[0_20px_45px_rgba(16,179,137,0.28)]">
							<h2 class="text-[1.35rem] font-semibold">Assistant IA</h2>
							<p class="mt-3 text-[0.96rem] leading-7 text-white/80">Posez vos questions nutritionnelles ou demandez des suggestions de recettes personnalisées.</p>
							<a href="/assistant" class="mt-5 inline-flex min-h-[46px] w-full items-center justify-center rounded-[14px] bg-white px-5 py-3 text-[0.96rem] font-semibold text-[#0b8c5f]">Discuter avec l’IA</a>
						</section>

						<section class="rounded-[24px] border border-[#d8e2ee] bg-white p-5 shadow-[0_16px_38px_rgba(71,104,145,0.08)]">
							<h2 class="text-[1.32rem] font-semibold text-[#16223c]">Progression hebdomadaire</h2>
							<div id="dashboard-week-bars" class="mt-6 flex h-[150px] items-end justify-between gap-2"></div>
						</section>

						<section class="rounded-[24px] border border-[#d8e2ee] bg-white p-5 shadow-[0_16px_38px_rgba(71,104,145,0.08)]">
							<h2 class="text-[1.32rem] font-semibold text-[#16223c]">Récompenses</h2>
							<div id="dashboard-rewards" class="mt-5 grid gap-4"></div>
						</section>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	const authKey = 'nutrivia_auth';
	const errorBox = document.querySelector('#dashboard-error');
	let dashboard = null;

	function getStoredAuth() {
		try {
			const raw = localStorage.getItem(authKey);
			return raw ? JSON.parse(raw) : null;
		} catch {
			return null;
		}
	}

	function setStoredAuth(payload) {
		localStorage.setItem(authKey, JSON.stringify(payload));
	}

	function clearStoredAuth() {
		localStorage.removeItem(authKey);
	}

	function showError(message) {
		if (!(errorBox instanceof HTMLElement)) return;
		errorBox.textContent = message;
		errorBox.classList.remove('hidden');
	}

	function clearError() {
		if (!(errorBox instanceof HTMLElement)) return;
		errorBox.classList.add('hidden');
		errorBox.textContent = '';
	}

	function esc(value) {
		return String(value ?? '')
			.replaceAll('&', '&amp;')
			.replaceAll('<', '&lt;')
			.replaceAll('>', '&gt;')
			.replaceAll('"', '&quot;')
			.replaceAll("'", '&#39;');
	}

	function fmt(value) {
		const number = Number(value ?? 0);
		return Number.isInteger(number) ? String(number) : number.toFixed(1).replace('.0', '');
	}

	function pct(consumed, target) {
		if (!target) return 0;
		return Math.max(0, Math.min(100, Math.round((Number(consumed) / Number(target)) * 100)));
	}

	function renderDashboard() {
		if (!dashboard) return;

		document.querySelector('#dashboard-greeting').textContent = `Bonjour, ${dashboard.user.firstName}`;
		document.querySelector('#dashboard-date').textContent = dashboard.today.dateLabel;
		document.querySelector('#dashboard-calories-consumed').textContent = fmt(dashboard.today.caloriesConsumed);
		document.querySelector('#dashboard-calories-target').textContent = `sur ${fmt(dashboard.today.caloriesTarget)} kcal`;
		document.querySelector('#dashboard-calories-remaining').textContent = `${fmt(dashboard.today.caloriesRemaining)} restantes`;

		const dayRate = pct(dashboard.today.caloriesConsumed, dashboard.today.caloriesTarget);
		const ring = document.querySelector('#dashboard-ring');
		if (ring instanceof HTMLElement) {
			ring.style.background = `conic-gradient(#08b37d 0deg, #08b37d ${Math.round(dayRate * 3.6)}deg, #e6edf6 ${Math.round(dayRate * 3.6)}deg, #e6edf6 360deg)`;
		}

		document.querySelector('#dashboard-proteins-label').textContent = `${fmt(dashboard.today.proteinsConsumed)} / ${fmt(dashboard.today.proteinsTarget)} g`;
		document.querySelector('#dashboard-carbs-label').textContent = `${fmt(dashboard.today.carbsConsumed)} / ${fmt(dashboard.today.carbsTarget)} g`;
		document.querySelector('#dashboard-fats-label').textContent = `${fmt(dashboard.today.fatsConsumed)} / ${fmt(dashboard.today.fatsTarget)} g`;
		document.querySelector('#dashboard-proteins-bar').style.width = `${pct(dashboard.today.proteinsConsumed, dashboard.today.proteinsTarget)}%`;
		document.querySelector('#dashboard-carbs-bar').style.width = `${pct(dashboard.today.carbsConsumed, dashboard.today.carbsTarget)}%`;
		document.querySelector('#dashboard-fats-bar').style.width = `${pct(dashboard.today.fatsConsumed, dashboard.today.fatsTarget)}%`;

		document.querySelector('#dashboard-sport-title').textContent = dashboard.user.activityLabel;
		document.querySelector('#dashboard-sport-subtitle').textContent = dashboard.sportMode.subtitle;
		document.querySelector('#dashboard-protein-kg').textContent = fmt(dashboard.sportMode.proteinsPerKg);
		document.querySelector('#dashboard-calorie-adjustment').textContent = dashboard.sportMode.calorieAdjustment;
		document.querySelector('#dashboard-water').textContent = `${fmt(dashboard.sportMode.waterLiters)}L`;

		const planning = document.querySelector('#dashboard-day-planning');
		if (planning instanceof HTMLElement) {
			if (!dashboard.planningToday.length) {
				planning.innerHTML = '<div class="rounded-[18px] border border-dashed border-[#d8e2ee] px-4 py-5 text-[0.95rem] text-slate-400">Aucun repas planifié aujourd’hui. Ajoutez-en depuis le planificateur.</div>';
			} else {
				planning.innerHTML = dashboard.planningToday.map((item) => `
					<a href="/recette/${esc(item.slug ?? '')}" class="flex items-center gap-3 rounded-[18px] bg-[#fbfdff] p-3 transition hover:bg-[#f6fbff]">
						<div class="h-[58px] w-[58px] shrink-0 overflow-hidden rounded-[14px] bg-slate-100">${item.imageUrl ? `<img src="${esc(item.imageUrl)}" alt="${esc(item.title)}" class="h-full w-full object-cover" />` : ''}</div>
						<div class="min-w-0 flex-1">
							<p class="text-[0.84rem] font-medium uppercase tracking-[0.12em] text-slate-400">${esc(item.mealLabel)}</p>
							<p class="mt-1 truncate text-[1rem] font-semibold text-[#16223c]">${esc(item.title)}</p>
						</div>
						<div class="text-right">
							<p class="text-[1rem] font-semibold text-[#16223c]">${fmt(item.calories)}</p>
							<p class="mt-1 text-[0.82rem] text-slate-400">kcal</p>
						</div>
					</a>
				`).join('');
			}
		}

		const products = document.querySelector('#dashboard-products');
		if (products instanceof HTMLElement) {
			products.innerHTML = dashboard.products.map((item) => `
				<div class="rounded-[18px] border border-[#d8e2ee] p-4">
					<div class="flex items-start justify-between gap-3">
						<div>
							<p class="text-[0.82rem] text-slate-400">${esc(item.brand)}</p>
							<p class="mt-1 text-[1rem] font-semibold text-[#16223c]">${esc(item.title)}</p>
						</div>
						<span class="rounded-full bg-[#fff0e3] px-2.5 py-1 text-[0.74rem] font-medium text-[#ff7a1a]">${esc(item.badge)}</span>
					</div>
					<div class="mt-4 flex items-center justify-between gap-3">
						<p class="text-[1.8rem] font-semibold text-[#08b37d]">${esc(item.price)}</p>
						<a href="#" class="inline-flex min-h-[40px] items-center justify-center rounded-[12px] bg-[#08b37d] px-4 py-2 text-[0.88rem] font-semibold text-white">Voir l’offre</a>
					</div>
				</div>
			`).join('');
		}

		const recipes = document.querySelector('#dashboard-recipes');
		if (recipes instanceof HTMLElement) {
			recipes.innerHTML = dashboard.recommendedRecipes.map((item) => `
				<a href="/recette/${esc(item.slug)}" class="overflow-hidden rounded-[18px] border border-[#d8e2ee] bg-white transition hover:border-[#bfd3e8]">
					<div class="relative h-[170px] overflow-hidden bg-slate-100">
						${item.imageUrl ? `<img src="${esc(item.imageUrl)}" alt="${esc(item.title)}" class="h-full w-full object-cover" />` : ''}
						<span class="absolute right-3 top-3 rounded-full bg-[#2d63ff] px-3 py-1 text-[0.74rem] font-medium text-white">${esc(item.badge)}</span>
					</div>
					<div class="p-4">
						<p class="text-[1.02rem] font-semibold text-[#16223c]">${esc(item.title)}</p>
						<p class="mt-2 text-[0.9rem] text-slate-500">${fmt(item.calories)} kcal · ${fmt(item.duration)} min</p>
					</div>
				</a>
			`).join('');
		}

		const weekBars = document.querySelector('#dashboard-week-bars');
		if (weekBars instanceof HTMLElement) {
			const maxCalories = Math.max(...dashboard.weekly.days.map((day) => Number(day.calories ?? 0)), 1);
			weekBars.innerHTML = dashboard.weekly.days.map((day) => {
				const height = Math.max(16, Math.round((Number(day.calories ?? 0) / maxCalories) * 108));
				const color = day.status === 'good' ? '#08b37d' : day.status === 'medium' ? '#f3b11f' : '#ff6b6b';
				return `<div class="flex flex-1 flex-col items-center justify-end gap-2"><div class="flex w-full items-end justify-center rounded-t-[10px]" style="height:${height}px;background:${color}"><span class="pb-2 text-[0.74rem] font-semibold text-white">${fmt(day.calories)}</span></div><span class="text-[0.82rem] font-medium ${day.isSelected ? 'text-[#08b37d]' : 'text-slate-400'}">${esc(day.label)}</span></div>`;
			}).join('');
		}

		const rewards = document.querySelector('#dashboard-rewards');
		if (rewards instanceof HTMLElement) {
			const tones = {
				green: 'bg-[#e9fbf2] text-[#0b8c5f]',
				blue: 'bg-[#eef4ff] text-[#2d63ff]',
				amber: 'bg-[#fff5e8] text-[#f59e0b]',
			};
			const icons = {
				green: '<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none"><path d="M12 3c-1.5 3-4 5.2-4 9a4 4 0 1 0 8 0c0-1.6-.5-3-1.4-4.3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>',
				blue: '<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none"><path d="M8 4h8v2a4 4 0 0 0 4 4v1a6 6 0 0 1-5 5.91V20H9v-3.09A6 6 0 0 1 4 11v-1a4 4 0 0 0 4-4V4Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>',
				amber: '<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none"><path d="M12 4v16M4 12h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.8"></circle></svg>',
			};
			rewards.innerHTML = dashboard.rewards.map((item) => `
				<div class="flex items-start gap-3">
					<span class="flex h-11 w-11 items-center justify-center rounded-[14px] ${tones[item.tone]}">${icons[item.tone]}</span>
					<div>
						<p class="text-[1rem] font-semibold text-[#16223c]">${esc(item.title)}</p>
						<p class="mt-1 text-[0.88rem] text-slate-500">${esc(item.subtitle)}</p>
					</div>
				</div>
			`).join('');
		}
	}

	async function fetchDashboard() {
		const auth = getStoredAuth();
		if (!auth?.token) {
			window.location.href = '/auth/login';
			return;
		}

		const response = await fetch('/app-api/dashboard', {
			headers: { Authorization: `Bearer ${auth.token}` },
		});
		const result = await response.json();
		if (!response.ok) {
			if (response.status === 401) {
				clearStoredAuth();
				window.location.href = '/auth/login';
				return;
			}
			throw new Error(result.message || 'Impossible de charger le tableau de bord.');
		}

		setStoredAuth({ ...auth, token: result.token, record: auth.record });
		dashboard = result;
		renderDashboard();
	}

	(async () => {
		try {
			clearError();
			await fetchDashboard();
		} catch (error) {
			showError(error instanceof Error ? error.message : 'Impossible de charger le tableau de bord.');
		}
	})();
</script>

