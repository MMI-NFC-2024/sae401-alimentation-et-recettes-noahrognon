---
import Layout from '../../layouts/Layout.astro';

const professionalName = Astro.url.searchParams.get('pro') ?? 'Professionnel';
const dateLabel = Astro.url.searchParams.get('date') ?? '';
const timeLabel = Astro.url.searchParams.get('time') ?? '';
---

<Layout title="Confirmation du rendez-vous">
	<section class="bg-[radial-gradient(circle_at_top_left,_rgba(205,248,224,0.75),_transparent_42%),linear-gradient(180deg,#fbffff_0%,#f5fbff_100%)]">
		<div class="mx-auto max-w-[920px] px-4 py-10 md:px-6 md:py-14">
			<div class="rounded-[32px] border border-[#d8e5f1] bg-white p-6 text-center shadow-[0_24px_80px_rgba(15,23,42,0.08)] md:p-10">
				<div class="mx-auto flex h-20 w-20 items-center justify-center rounded-[28px] bg-[linear-gradient(135deg,#08b37d_0%,#5cd6b5_100%)] text-4xl text-white">✓</div>
				<h1 class="mt-6 text-3xl font-semibold tracking-[-0.03em] text-slate-900 md:text-4xl">Rendez-vous confirmé</h1>
				<p class="mx-auto mt-4 max-w-[560px] text-base leading-7 text-slate-600">
					Votre réservation a bien été prise en compte. Vous retrouverez ce rendez-vous dans votre espace professionnel et dans vos prochaines consultations.
				</p>

				<div class="mt-8 grid gap-4 md:grid-cols-3">
					<div class="rounded-[24px] bg-slate-50 p-5">
						<p class="text-xs font-medium uppercase tracking-[0.14em] text-slate-400">Professionnel</p>
						<p class="mt-2 text-lg font-semibold text-slate-900">{professionalName}</p>
					</div>
					<div class="rounded-[24px] bg-slate-50 p-5">
						<p class="text-xs font-medium uppercase tracking-[0.14em] text-slate-400">Date</p>
						<p class="mt-2 text-lg font-semibold text-slate-900">{dateLabel || 'À confirmer'}</p>
					</div>
					<div class="rounded-[24px] bg-slate-50 p-5">
						<p class="text-xs font-medium uppercase tracking-[0.14em] text-slate-400">Créneau</p>
						<p class="mt-2 text-lg font-semibold text-slate-900">{timeLabel || 'À confirmer'}</p>
					</div>
				</div>

				<div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
					<a href="/professionnels" class="inline-flex items-center justify-center rounded-[18px] bg-[#08b37d] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#079765]">
						Retour aux professionnels
					</a>
					<a href="/dashboard" class="inline-flex items-center justify-center rounded-[18px] border border-[#cad8e7] bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-[#08b37d] hover:text-[#08b37d]">
						Aller au tableau de bord
					</a>
				</div>
			</div>
		</div>
	</section>
</Layout>
