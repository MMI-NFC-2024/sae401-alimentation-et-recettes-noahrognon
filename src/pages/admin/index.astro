---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Back-office admin - Nutrivia">
	<section class="bg-[radial-gradient(circle_at_top_left,_rgba(205,248,224,0.75),_transparent_42%),linear-gradient(180deg,#fbffff_0%,#f5fbff_100%)]">
		<div class="mx-auto max-w-[1380px] px-4 py-8 md:px-6 md:py-10">
			<div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
				<div>
					<span class="inline-flex rounded-full bg-[#d8f7e1] px-3 py-1 text-sm font-semibold text-[#0a9a68]">Back-office</span>
					<h1 class="mt-4 text-3xl font-semibold tracking-[-0.03em] text-slate-900 md:text-[2.7rem]">Administration Nutrivia</h1>
					<p class="mt-3 max-w-[760px] text-base leading-7 text-slate-600">Validation, modération, analytics et création manuelle de contenus.</p>
				</div>
				<div class="flex flex-wrap gap-3">
					<a href="/dashboard" class="inline-flex items-center justify-center rounded-[18px] border border-[#cad8e7] bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-[#08b37d] hover:text-[#08b37d]">Retour au site</a>
					<button id="admin-logout" type="button" class="inline-flex items-center justify-center rounded-[18px] bg-[#16223c] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#0f172a]">Déconnexion admin</button>
				</div>
			</div>

			<div id="admin-auth-needed" class="mt-8 hidden rounded-[28px] border border-[#d8e5f1] bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-8">
				<h2 class="text-2xl font-semibold text-slate-900">Session admin requise</h2>
				<p class="mt-3 text-sm leading-6 text-slate-600">Connectez-vous avec un compte administrateur PocketBase pour accéder au back-office.</p>
				<a href="/admin/login" class="mt-5 inline-flex rounded-[18px] bg-[#16223c] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#0f172a]">Se connecter</a>
			</div>

			<div id="admin-error" class="mt-8 hidden rounded-2xl border border-[#ffd8d8] bg-[#fff6f6] px-4 py-3 text-sm font-medium text-[#c24141]"></div>
			<div id="admin-loading" class="mt-8 text-sm font-medium text-slate-500">Chargement du back-office...</div>

			<div id="admin-shell" class="mt-8 hidden space-y-6">
				<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4 2xl:grid-cols-8">
					<div class="rounded-[24px] bg-[linear-gradient(135deg,#08b37d_0%,#5cd6b5_100%)] p-5 text-white shadow-[0_24px_70px_rgba(8,179,125,0.28)]"><p class="text-sm text-white/75">Utilisateurs</p><p id="stat-users" class="mt-2 text-4xl font-semibold">0</p></div>
					<div class="rounded-[24px] border border-[#d8e5f1] bg-white p-5"><p class="text-sm text-slate-500">Recettes</p><p id="stat-recipes" class="mt-2 text-4xl font-semibold text-slate-900">0</p></div>
					<div class="rounded-[24px] border border-[#d8e5f1] bg-white p-5"><p class="text-sm text-slate-500">Aliments</p><p id="stat-foods" class="mt-2 text-4xl font-semibold text-slate-900">0</p></div>
					<div class="rounded-[24px] border border-[#d8e5f1] bg-white p-5"><p class="text-sm text-slate-500">Professionnels</p><p id="stat-pros" class="mt-2 text-4xl font-semibold text-slate-900">0</p></div>
					<div class="rounded-[24px] border border-[#d8e5f1] bg-white p-5"><p class="text-sm text-slate-500">Rendez-vous</p><p id="stat-appointments" class="mt-2 text-4xl font-semibold text-slate-900">0</p></div>
					<div class="rounded-[24px] border border-[#d8e5f1] bg-white p-5"><p class="text-sm text-slate-500">Recettes à valider</p><p id="stat-pending-recipes" class="mt-2 text-4xl font-semibold text-[#c67a09]">0</p></div>
					<div class="rounded-[24px] border border-[#d8e5f1] bg-white p-5"><p class="text-sm text-slate-500">Aliments à valider</p><p id="stat-pending-foods" class="mt-2 text-4xl font-semibold text-[#c67a09]">0</p></div>
					<div class="rounded-[24px] border border-[#d8e5f1] bg-white p-5"><p class="text-sm text-slate-500">Contenus masqués</p><p id="stat-hidden-content" class="mt-2 text-4xl font-semibold text-[#c24141]">0</p></div>
				</div>

				<div class="rounded-[26px] border border-[#d8e5f1] bg-white p-4 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-5">
					<div id="admin-tabs" class="flex flex-wrap gap-2"></div>
				</div>

				<section id="admin-tab-dashboard" class="admin-tab-content space-y-6">
					<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
						<div class="rounded-[24px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)]"><p class="text-sm text-slate-500">Recettes publiées</p><p id="dash-published-recipes" class="mt-2 text-3xl font-semibold text-slate-900">0</p></div>
						<div class="rounded-[24px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)]"><p class="text-sm text-slate-500">Pros actifs</p><p id="dash-active-pros" class="mt-2 text-3xl font-semibold text-slate-900">0</p></div>
						<div class="rounded-[24px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)]"><p class="text-sm text-slate-500">Posts</p><p id="dash-posts" class="mt-2 text-3xl font-semibold text-slate-900">0</p></div>
						<div class="rounded-[24px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)]"><p class="text-sm text-slate-500">Commentaires</p><p id="dash-comments" class="mt-2 text-3xl font-semibold text-slate-900">0</p></div>
					</div>
					<div class="grid gap-6 2xl:grid-cols-[minmax(0,1.2fr)_420px]">
						<div class="grid gap-6 xl:grid-cols-2">
							<section class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7"><div class="flex items-center justify-between gap-4"><h2 class="text-2xl font-semibold text-slate-900">Utilisateurs récents</h2><span id="viewer-email" class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"></span></div><div id="admin-recent-users" class="mt-6 grid gap-3"></div></section>
							<section class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7"><h2 class="text-2xl font-semibold text-slate-900">Top publications</h2><div id="admin-top-posts" class="mt-6 space-y-3"></div></section>
						</div>
						<div class="space-y-6">
							<section class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7"><h2 class="text-2xl font-semibold text-slate-900">Actions prioritaires</h2><div id="admin-priority-actions" class="mt-6 space-y-3"></div></section>
							<section class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7"><h2 class="text-2xl font-semibold text-slate-900">Rendez-vous à venir</h2><div id="admin-upcoming-appointments" class="mt-6 space-y-3"></div></section>
						</div>
					</div>
				</section>

				<section id="admin-tab-validations" class="admin-tab-content hidden">
					<div class="grid gap-6 xl:grid-cols-3">
						<section class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7"><h2 class="text-2xl font-semibold text-slate-900">Recettes à valider</h2><div id="admin-pending-recipes" class="mt-6 space-y-3"></div></section>
						<section class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7"><h2 class="text-2xl font-semibold text-slate-900">Aliments à valider</h2><div id="admin-pending-foods" class="mt-6 space-y-3"></div></section>
						<section class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7"><h2 class="text-2xl font-semibold text-slate-900">Professionnels à valider</h2><div id="admin-pending-professionals" class="mt-6 space-y-3"></div></section>
					</div>
				</section>

				<section id="admin-tab-users" class="admin-tab-content hidden rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7">
					<div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between"><div><h2 class="text-2xl font-semibold text-slate-900">Gestion utilisateurs</h2><p class="mt-2 text-sm text-slate-500">Recherche rapide et changement de rôle.</p></div><input id="admin-users-search" type="search" placeholder="Rechercher un utilisateur..." class="h-12 w-full rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none lg:max-w-[320px]" /></div>
					<div id="admin-users-list" class="mt-6 space-y-3"></div>
				</section>

				<section id="admin-tab-recipes" class="admin-tab-content hidden space-y-6">
					<section class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7">
						<h2 class="text-2xl font-semibold text-slate-900">Ajouter une recette</h2>
						<form id="admin-add-recipe-form" class="mt-6 grid gap-4 xl:grid-cols-2">
							<input name="title" required placeholder="Titre" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<select name="goalId" id="admin-recipe-goal" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none"></select>
							<textarea name="description" rows="4" placeholder="Description" class="rounded-[16px] border border-[#cad8e7] px-4 py-3 text-sm text-slate-700 outline-none xl:col-span-2"></textarea>
							<input name="timeMinutes" type="number" min="0" placeholder="Temps total (min)" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<input name="portions" type="number" min="1" placeholder="Portions" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<input name="calories" type="number" min="0" placeholder="Calories / portion" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<input name="proteins" type="number" min="0" step="0.1" placeholder="Protéines (g)" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<input name="carbs" type="number" min="0" step="0.1" placeholder="Glucides (g)" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<input name="fats" type="number" min="0" step="0.1" placeholder="Lipides (g)" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<input name="fibers" type="number" min="0" step="0.1" placeholder="Fibres (g)" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<select name="difficulty" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none"><option value="facile">Facile</option><option value="moyen">Moyen</option><option value="difficile">Difficile</option></select>
							<select name="validationStatus" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none"><option value="approved">Approuvée</option><option value="pending">À valider</option><option value="rejected">Refusée</option></select>
							<label class="xl:col-span-2 inline-flex items-center gap-2 text-sm font-medium text-slate-700"><input name="published" type="checkbox" checked class="h-4 w-4 rounded border-slate-300 text-[#08b37d] focus:ring-[#08b37d]" />Publier immédiatement</label>
							<textarea name="ingredientsText" rows="6" placeholder="Ingrédients, un par ligne&#10;Ex: Filet de saumon - 180 g" class="rounded-[16px] border border-[#cad8e7] px-4 py-3 text-sm text-slate-700 outline-none"></textarea>
							<textarea name="stepsText" rows="6" placeholder="Étapes, une par ligne" class="rounded-[16px] border border-[#cad8e7] px-4 py-3 text-sm text-slate-700 outline-none"></textarea>
							<label class="xl:col-span-2 grid gap-2 text-sm font-medium text-slate-700">Image optionnelle<input id="admin-recipe-image" type="file" accept="image/*" class="rounded-[16px] border border-dashed border-[#cad8e7] px-4 py-4 text-sm text-slate-500" /></label>
							<div class="xl:col-span-2 flex justify-end"><button type="submit" class="inline-flex items-center justify-center rounded-[16px] bg-[#08b37d] px-5 py-3 text-sm font-semibold text-white">Ajouter la recette</button></div>
						</form>
					</section>
					<section class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7">
						<div class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between"><div><h2 class="text-2xl font-semibold text-slate-900">Gestion des recettes</h2><p class="mt-2 text-sm text-slate-500">Filtrez, publiez et validez le catalogue.</p></div><div class="grid gap-3 md:grid-cols-2 xl:w-[560px]"><input id="admin-recipes-search" type="search" placeholder="Rechercher une recette..." class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" /><select id="admin-recipes-status" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none"><option value="">Tous les statuts</option><option value="pending">À valider</option><option value="approved">Approuvées</option><option value="rejected">Refusées</option></select></div></div>
						<div id="admin-recipes-list" class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3"></div>
					</section>
				</section>

				<section id="admin-tab-foods" class="admin-tab-content hidden space-y-6">
					<section class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7">
						<h2 class="text-2xl font-semibold text-slate-900">Ajouter un aliment</h2>
						<form id="admin-add-food-form" class="mt-6 grid gap-4 xl:grid-cols-2">
							<input name="name" required placeholder="Nom de l'aliment" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<select name="category" id="admin-food-category" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none"></select>
							<textarea name="description" rows="4" placeholder="Description" class="rounded-[16px] border border-[#cad8e7] px-4 py-3 text-sm text-slate-700 outline-none xl:col-span-2"></textarea>
							<input name="calories" type="number" min="0" placeholder="Calories / 100g" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<input name="proteins" type="number" min="0" step="0.1" placeholder="Protéines / 100g" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<input name="carbs" type="number" min="0" step="0.1" placeholder="Glucides / 100g" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<input name="fats" type="number" min="0" step="0.1" placeholder="Lipides / 100g" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<input name="fibers" type="number" min="0" step="0.1" placeholder="Fibres / 100g" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<input name="unit" placeholder="Unité par défaut (g, ml, pièce...)" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" />
							<select name="validationStatus" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none"><option value="approved">Approuvé</option><option value="pending">À valider</option><option value="rejected">Refusé</option></select>
							<label class="xl:col-span-2 grid gap-2 text-sm font-medium text-slate-700">Image optionnelle<input id="admin-food-image" type="file" accept="image/*" class="rounded-[16px] border border-dashed border-[#cad8e7] px-4 py-4 text-sm text-slate-500" /></label>
							<div class="xl:col-span-2 flex justify-end"><button type="submit" class="inline-flex items-center justify-center rounded-[16px] bg-[#08b37d] px-5 py-3 text-sm font-semibold text-white">Ajouter l'aliment</button></div>
						</form>
					</section>
					<section class="rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7">
						<div class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between"><div><h2 class="text-2xl font-semibold text-slate-900">Base aliments</h2><p class="mt-2 text-sm text-slate-500">Validez et supprimez les aliments si nécessaire.</p></div><div class="grid gap-3 md:grid-cols-2 xl:w-[560px]"><input id="admin-foods-search" type="search" placeholder="Rechercher un aliment..." class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none" /><select id="admin-foods-status" class="h-12 rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none"><option value="">Tous les statuts</option><option value="pending">À valider</option><option value="approved">Approuvés</option><option value="rejected">Refusés</option></select></div></div>
						<div id="admin-foods-list" class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3"></div>
					</section>
				</section>

				<section id="admin-tab-community" class="admin-tab-content hidden rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7">
					<div class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between"><div><h2 class="text-2xl font-semibold text-slate-900">Modération communauté</h2><p class="mt-2 text-sm text-slate-500">Masquez ou supprimez les publications et commentaires.</p></div><input id="admin-community-search" type="search" placeholder="Rechercher dans la communauté..." class="h-12 w-full rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none xl:max-w-[340px]" /></div>
					<div class="mt-6 grid gap-6 xl:grid-cols-2"><div><h3 class="text-lg font-semibold text-slate-900">Publications</h3><div id="admin-posts-list" class="mt-4 space-y-3"></div></div><div><h3 class="text-lg font-semibold text-slate-900">Commentaires</h3><div id="admin-comments-list" class="mt-4 space-y-3"></div></div></div>
				</section>

				<section id="admin-tab-professionals" class="admin-tab-content hidden rounded-[28px] border border-[#d8e5f1] bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-7">
					<div class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between"><div><h2 class="text-2xl font-semibold text-slate-900">Professionnels & rendez-vous</h2><p class="mt-2 text-sm text-slate-500">Validez les profils et suivez les réservations.</p></div><input id="admin-professionals-search" type="search" placeholder="Rechercher un professionnel..." class="h-12 w-full rounded-[16px] border border-[#cad8e7] px-4 text-sm text-slate-700 outline-none xl:max-w-[340px]" /></div>
					<div class="mt-6 grid gap-6 xl:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]"><div id="admin-professionals-list" class="space-y-3"></div><div id="admin-appointments-list" class="space-y-3"></div></div>
				</section>
			</div>
		</div>
	</section>
</Layout>

<script is:inline src="/admin-backoffice.js"></script>
