---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Professionnels nutrition';
---

<Layout title={pageTitle}>
	<section class="bg-[radial-gradient(circle_at_top_left,_rgba(205,248,224,0.75),_transparent_42%),linear-gradient(180deg,#fbffff_0%,#f5fbff_100%)]">
		<div class="mx-auto max-w-[1180px] px-4 py-8 md:px-6 md:py-10">
			<div class="space-y-3">
				<span class="inline-flex rounded-full bg-[#d8f7e1] px-3 py-1 text-sm font-semibold text-[#0a9a68]">Consultations nutrition</span>
				<div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
					<div class="max-w-[720px]">
						<h1 class="text-3xl font-semibold tracking-[-0.03em] text-slate-900 md:text-[2.55rem]">Professionnels de la nutrition</h1>
						<p class="mt-3 text-base leading-7 text-slate-600 md:text-lg">
							Réservez un rendez-vous avec un diététicien, nutritionniste ou coach alimentaire directement depuis Nutrivia.
						</p>
					</div>

					<div class="flex flex-col gap-3 sm:flex-row">
						<a
							href="/mes-rendez-vous"
							class="inline-flex items-center justify-center rounded-[18px] bg-[#08b37d] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#079765]"
						>
							Voir mes rendez-vous
						</a>
						<a
							href="/espace-pro"
							class="inline-flex items-center justify-center rounded-[18px] border border-[#bfe6d4] bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-[#08b37d] hover:text-[#08b37d]"
						>
							Espace professionnel
						</a>
					</div>
				</div>
			</div>

			<div class="mt-8 rounded-[28px] border border-[#d8e5f1] bg-white/90 p-4 shadow-[0_20px_60px_rgba(15,23,42,0.07)] md:p-6">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p class="text-lg font-semibold text-slate-900">Trouver le bon spécialiste</p>
						<p class="mt-1 text-sm text-slate-500">Filtrez par spécialité et consultez les créneaux disponibles.</p>
					</div>
					<div id="professionals-filters" class="flex flex-wrap gap-2"></div>
				</div>

				<div id="professionals-feedback" class="mt-5 hidden rounded-2xl border border-[#ffd8d8] bg-[#fff6f6] px-4 py-3 text-sm font-medium text-[#c24141]"></div>
				<div id="professionals-loading" class="mt-8 text-sm font-medium text-slate-500">Chargement des professionnels...</div>
				<div id="professionals-grid" class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3"></div>
			</div>
		</div>
	</section>
</Layout>

<script>
	const filtersContainer = document.querySelector('#professionals-filters');
	const grid = document.querySelector('#professionals-grid');
	const loading = document.querySelector('#professionals-loading');
	const feedback = document.querySelector('#professionals-feedback');
	const params = new URLSearchParams(window.location.search);

	function escapeHtml(value) {
		return String(value ?? '')
			.replaceAll('&', '&amp;')
			.replaceAll('<', '&lt;')
			.replaceAll('>', '&gt;')
			.replaceAll('"', '&quot;')
			.replaceAll("'", '&#039;');
	}

	function showFeedback(message = '') {
		if (!feedback) return;
		feedback.textContent = message;
		feedback.classList.toggle('hidden', !message);
	}

	function renderFilters(filters, selected) {
		if (!filtersContainer) return;
		filtersContainer.innerHTML = filters
			.map(
				(filter) => `
					<button
						type="button"
						data-speciality="${escapeHtml(filter.slug)}"
						class="rounded-full border px-4 py-2 text-sm font-medium transition ${
							filter.slug === selected
								? 'border-[#08b37d] bg-[#d8f7e1] text-[#0a9a68]'
								: 'border-[#d5e2ee] bg-white text-slate-600 hover:border-[#08b37d] hover:text-[#08b37d]'
						}"
					>
						${escapeHtml(filter.label)}
					</button>
				`,
			)
			.join('');

		Array.from(filtersContainer.querySelectorAll('button[data-speciality]')).forEach((button) => {
			button.addEventListener('click', () => {
				const speciality = button.getAttribute('data-speciality') ?? '';
				if (speciality) {
					params.set('specialite', speciality);
				} else {
					params.delete('specialite');
				}
				const nextUrl = `${window.location.pathname}${params.toString() ? `?${params.toString()}` : ''}`;
				window.history.replaceState({}, '', nextUrl);
				loadProfessionals();
			});
		});
	}

	function renderProfessionals(items) {
		if (!grid) return;
		if (!items.length) {
			grid.innerHTML = `
				<div class="rounded-[24px] border border-dashed border-[#cad8e7] bg-white/70 p-8 text-center text-slate-500 md:col-span-2 xl:col-span-3">
					Aucun professionnel ne correspond à ce filtre pour le moment.
				</div>
			`;
			return;
		}

		grid.innerHTML = items
			.map(
				(item) => `
					<article class="flex h-full flex-col rounded-[24px] border border-[#d8e5f1] bg-white p-5 shadow-[0_12px_40px_rgba(15,23,42,0.06)]">
						<div class="flex items-start gap-4">
							<div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[linear-gradient(135deg,#08b37d_0%,#5cd6b5_100%)] text-lg font-semibold text-white">
								${escapeHtml(item.initials)}
							</div>
							<div class="min-w-0 flex-1">
								<p class="text-lg font-semibold text-slate-900">${escapeHtml(item.name)}</p>
								<p class="mt-1 text-sm font-medium text-[#08b37d]">${escapeHtml(item.specialityLabel)}</p>
								<p class="mt-2 text-sm text-slate-500">${escapeHtml(item.city || 'Consultation en ligne')}</p>
							</div>
						</div>

						<p class="mt-4 line-clamp-4 text-sm leading-6 text-slate-600">${escapeHtml(item.description)}</p>

						<div class="mt-4 flex flex-wrap gap-2">
							${(item.consultationModes || [])
								.map(
									(mode) => `
										<span class="rounded-full bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-600">${escapeHtml(mode)}</span>
									`,
								)
								.join('')}
						</div>

						<div class="mt-5 grid grid-cols-2 gap-3 rounded-[18px] bg-slate-50 p-3">
							<div>
								<p class="text-xs font-medium uppercase tracking-[0.12em] text-slate-400">Expérience</p>
								<p class="mt-1 text-sm font-semibold text-slate-700">${escapeHtml(item.experienceYears || 0)} ans</p>
							</div>
							<div>
								<p class="text-xs font-medium uppercase tracking-[0.12em] text-slate-400">Consultation</p>
								<p class="mt-1 text-sm font-semibold text-slate-700">${escapeHtml(item.price || 0)} €</p>
							</div>
						</div>

						<div class="mt-5 flex gap-3">
							<a
								href="/professionnels/${escapeHtml(item.slug)}"
								class="inline-flex flex-1 items-center justify-center rounded-[16px] bg-[#08b37d] px-4 py-3 text-sm font-semibold text-white transition hover:bg-[#079765]"
							>
								Voir le profil
							</a>
						</div>
					</article>
				`,
			)
			.join('');
	}

	async function loadProfessionals() {
		showFeedback('');
		if (loading) loading.classList.remove('hidden');
		if (grid) grid.innerHTML = '';

		const speciality = params.get('specialite') ?? '';
		const query = speciality ? `?specialite=${encodeURIComponent(speciality)}` : '';

		try {
			const response = await fetch(`/app-api/professionals${query}`);
			const payload = await response.json();
			if (!response.ok) {
				throw new Error(payload.message || 'Impossible de charger les professionnels.');
			}

			renderFilters(payload.filters || [], payload.selectedSpeciality || '');
			renderProfessionals(payload.professionals || []);
		} catch (error) {
			showFeedback(error instanceof Error ? error.message : 'Impossible de charger les professionnels.');
		} finally {
			if (loading) loading.classList.add('hidden');
		}
	}

	loadProfessionals();
</script>
