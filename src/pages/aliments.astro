---
import Layout from '../layouts/Layout.astro';

const foodsJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Base de données alimentaires Nutrivia',
	url: 'https://nutrivia.noahrognon.fr/aliments',
	description: 'Base de données nutritionnelles avec calories, protéines, glucides, lipides et fibres pour composer des repas équilibrés.',
};
---

<Layout
	title="Base alimentaire : calories et macros - Nutrivia"
	description="Consultez les valeurs nutritionnelles des aliments : calories, protéines, glucides, lipides et fibres pour mieux composer vos repas et suivre votre alimentation."
	jsonLd={foodsJsonLd}
>
	<section class="bg-[radial-gradient(circle_at_left_top,rgba(214,247,223,0.78),transparent_28%),radial-gradient(circle_at_right_bottom,rgba(218,236,255,0.72),transparent_32%),linear-gradient(180deg,#f6fdf9_0%,#fbfdff_64%,#f4f9ff_100%)] py-8 lg:py-10">
		<div class="mx-auto max-w-[1180px] px-4 md:px-6">
			<div class="mx-auto max-w-[1080px]">
				<div class="mb-7">
					<h1 class="text-[2.3rem] font-semibold tracking-[-0.04em] text-[#16223c]">Base de données alimentaires</h1>
					<p class="mt-2 text-[1.05rem] text-slate-500">Consultez les valeurs nutritionnelles de milliers d'aliments</p>
				</div>

				<p id="foods-error" class="mb-5 hidden rounded-2xl bg-red-50 px-4 py-3 text-sm text-red-600"></p>

				<div class="grid gap-4 lg:grid-cols-2">
					<button id="foods-scan-trigger" type="button" class="relative overflow-hidden rounded-[22px] bg-[linear-gradient(135deg,#08b37d_0%,#08a487_100%)] px-6 py-5 text-left text-white shadow-[0_18px_42px_rgba(8,179,125,0.22)] transition hover:translate-y-[-1px]">
						<div class="absolute top-0 right-0 h-28 w-28 rounded-full bg-white/12 blur-sm"></div>
						<div class="relative flex items-center gap-4">
							<div class="flex h-[52px] w-[52px] items-center justify-center rounded-[16px] bg-white/16">
								<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" aria-hidden="true">
									<path d="M4 8a2 2 0 0 1 2-2h2l1-2h6l1 2h2a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
									<circle cx="12" cy="12" r="3.2" stroke="currentColor" stroke-width="1.8"></circle>
								</svg>
							</div>
							<div>
								<h2 class="text-[1.5rem] font-semibold">Scanner un produit</h2>
								<p class="mt-1 text-[1rem] text-white/85">Obtenez les infos nutritionnelles instantanément</p>
							</div>
						</div>
					</button>

					<a href="/scanner?mode=plate&return=/aliments" class="relative overflow-hidden rounded-[22px] bg-[linear-gradient(135deg,#8f39ff_0%,#ef2ea6_100%)] px-6 py-5 text-white shadow-[0_18px_42px_rgba(161,55,223,0.20)]">
						<div class="absolute top-0 right-0 h-28 w-28 rounded-full bg-white/12 blur-sm"></div>
						<div class="relative flex items-center gap-4">
							<div class="flex h-[52px] w-[52px] items-center justify-center rounded-[16px] bg-white/16">
								<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" aria-hidden="true">
									<path d="M12 3v4M12 17v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M3 12h4M17 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
								</svg>
							</div>
							<div>
								<h2 class="text-[1.5rem] font-semibold">Analyser une assiette</h2>
								<p class="mt-1 text-[1rem] text-white/85">Estimez les macros de vos repas à partir d’une photo</p>
							</div>
						</div>
					</a>
				</div>

				<div class="mt-6 rounded-[24px] border border-[#dbe7f2] bg-white/65 p-4 shadow-[0_16px_42px_rgba(71,104,145,0.08)] backdrop-blur-sm sm:p-5">
					<div class="relative">
						<svg viewBox="0 0 24 24" class="pointer-events-none absolute top-1/2 left-4 h-5 w-5 -translate-y-1/2 text-slate-400" fill="none" aria-hidden="true">
							<path d="M21 21l-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
						</svg>
						<input
							id="foods-search"
							type="search"
							placeholder="Rechercher un aliment..."
							class="h-[54px] w-full rounded-[18px] border border-[#cad8e7] bg-white pl-12 pr-4 text-[1rem] text-slate-700 outline-none transition placeholder:text-slate-400 focus:border-[#08b37d]"
						/>
					</div>

					<div id="foods-categories" class="mt-5 flex flex-wrap gap-3"></div>
				</div>

				<p id="foods-count" class="mt-7 text-[1.02rem] font-medium text-[#324765]">0 aliment trouvé</p>

				<div id="foods-grid" class="mt-6 grid gap-5 lg:grid-cols-2"></div>

				<div id="foods-empty" class="mt-8 hidden rounded-[24px] border border-dashed border-[#cad8e7] bg-white/70 px-6 py-10 text-center text-slate-500">
					Aucun aliment ne correspond à votre recherche.
				</div>
			</div>
		</div>

		<div id="food-scan-modal" class="pointer-events-none fixed inset-0 z-[80] hidden items-center justify-center bg-slate-950/45 p-4 opacity-0 transition md:p-6">
			<div class="flex max-h-[92vh] w-full max-w-[920px] flex-col overflow-hidden rounded-[28px] bg-white shadow-[0_24px_70px_rgba(15,23,42,0.28)]">
				<div class="flex items-center justify-between border-b border-[#e6eef7] px-5 py-4 md:px-6">
					<div>
						<h2 class="text-[1.4rem] font-semibold tracking-[-0.03em] text-[#16223c]">Scanner un produit</h2>
						<p class="mt-1 text-sm text-slate-500">Importez une photo du produit ou de son étiquette, puis validez la fiche avant ajout.</p>
					</div>
					<button id="food-scan-close" type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-[#d7e4f2] text-slate-500 transition hover:bg-slate-50" aria-label="Fermer">
						<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none"><path d="m7 7 10 10M17 7 7 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path></svg>
					</button>
				</div>
				<div class="min-h-0 flex-1 overflow-y-auto px-5 py-5 md:px-6">
					<p id="food-scan-error" class="mb-4 hidden rounded-2xl bg-red-50 px-4 py-3 text-sm text-red-600"></p>
					<div class="grid gap-5 lg:grid-cols-[0.92fr_1.08fr]">
						<div class="space-y-4">
							<input id="food-scan-input" type="file" accept="image/*" capture="environment" class="hidden" />
							<button id="food-scan-pick" type="button" class="flex min-h-[220px] w-full flex-col items-center justify-center rounded-[24px] border border-dashed border-[#bfd3e8] bg-[#f7fbff] px-6 py-8 text-center transition hover:border-[#08b37d] hover:bg-[#f3fbf7]">
								<div class="flex h-16 w-16 items-center justify-center rounded-[20px] bg-[#e7fbf3] text-[#08b37d]">
									<svg viewBox="0 0 24 24" class="h-7 w-7" fill="none"><path d="M4 8a2 2 0 0 1 2-2h2l1-2h6l1 2h2a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path><circle cx="12" cy="12" r="3.2" stroke="currentColor" stroke-width="1.8"></circle></svg>
								</div>
								<p class="mt-4 text-[1.02rem] font-medium text-[#16223c]">Choisir une photo</p>
								<p class="mt-2 max-w-[18rem] text-sm leading-6 text-slate-500">Photographiez le produit ou son tableau nutritionnel pour générer une fiche vérifiable.</p>
							</button>
							<div id="food-scan-preview-wrap" class="hidden overflow-hidden rounded-[24px] border border-[#d8e2ee] bg-white">
								<img id="food-scan-preview" alt="Aperçu du produit" class="h-[240px] w-full object-cover" />
							</div>
							<div class="rounded-[20px] bg-[#f6f9fd] px-4 py-4 text-sm leading-6 text-slate-500">
								L’analyse est assistée par IA. Vérifiez toujours la fiche avant l’enregistrement.
							</div>
						</div>

						<div class="space-y-4">
							<div class="flex items-center gap-3 rounded-[20px] border border-[#d8e2ee] bg-white px-4 py-4">
								<div id="food-scan-loader" class="hidden h-5 w-5 animate-spin rounded-full border-2 border-[#08b37d]/20 border-t-[#08b37d]"></div>
								<p id="food-scan-status" class="text-sm text-slate-500">Importez une image pour lancer l’analyse.</p>
							</div>

							<div id="food-scan-form" class="grid gap-4 rounded-[24px] border border-[#d8e2ee] bg-white p-4 md:grid-cols-2 md:p-5">
								<label class="space-y-2 md:col-span-2">
									<span class="text-sm font-medium text-slate-600">Nom</span>
									<input id="scan-food-name" type="text" class="h-[46px] w-full rounded-[16px] border border-[#cad8e7] px-4 text-slate-700 outline-none focus:border-[#08b37d]" />
								</label>
								<label class="space-y-2">
									<span class="text-sm font-medium text-slate-600">Marque</span>
									<input id="scan-food-brand" type="text" class="h-[46px] w-full rounded-[16px] border border-[#cad8e7] px-4 text-slate-700 outline-none focus:border-[#08b37d]" />
								</label>
								<label class="space-y-2">
									<span class="text-sm font-medium text-slate-600">Catégorie</span>
									<select id="scan-food-category" class="h-[46px] w-full rounded-[16px] border border-[#cad8e7] bg-white px-4 text-slate-700 outline-none focus:border-[#08b37d]">
										<option value="autre">Autre</option>
										<option value="viande">Viande</option>
										<option value="poisson">Poisson</option>
										<option value="produit_laitier">Produits laitiers</option>
										<option value="cereale">Céréales</option>
										<option value="legume">Légumes</option>
										<option value="fruit">Fruits</option>
										<option value="epicerie">Épicerie</option>
									</select>
								</label>
								<label class="space-y-2 md:col-span-2">
									<span class="text-sm font-medium text-slate-600">Description</span>
									<textarea id="scan-food-description" rows="3" class="w-full rounded-[16px] border border-[#cad8e7] px-4 py-3 text-slate-700 outline-none focus:border-[#08b37d]"></textarea>
								</label>
								<label class="space-y-2">
									<span class="text-sm font-medium text-slate-600">Unité</span>
									<select id="scan-food-unit" class="h-[46px] w-full rounded-[16px] border border-[#cad8e7] bg-white px-4 text-slate-700 outline-none focus:border-[#08b37d]">
										<option value="g">g</option>
										<option value="ml">ml</option>
										<option value="piece">pièce</option>
										<option value="portion">portion</option>
									</select>
								</label>
								<label class="space-y-2">
									<span class="text-sm font-medium text-slate-600">Confiance IA</span>
									<input id="scan-food-confidence" type="text" disabled class="h-[46px] w-full rounded-[16px] border border-[#e3ebf4] bg-slate-50 px-4 text-slate-500 outline-none" />
								</label>
								<label class="space-y-2">
									<span class="text-sm font-medium text-slate-600">Calories /100g</span>
									<input id="scan-food-calories" type="number" min="0" step="0.1" class="h-[46px] w-full rounded-[16px] border border-[#cad8e7] px-4 text-slate-700 outline-none focus:border-[#08b37d]" />
								</label>
								<label class="space-y-2">
									<span class="text-sm font-medium text-slate-600">Protéines /100g</span>
									<input id="scan-food-proteins" type="number" min="0" step="0.1" class="h-[46px] w-full rounded-[16px] border border-[#cad8e7] px-4 text-slate-700 outline-none focus:border-[#08b37d]" />
								</label>
								<label class="space-y-2">
									<span class="text-sm font-medium text-slate-600">Glucides /100g</span>
									<input id="scan-food-carbs" type="number" min="0" step="0.1" class="h-[46px] w-full rounded-[16px] border border-[#cad8e7] px-4 text-slate-700 outline-none focus:border-[#08b37d]" />
								</label>
								<label class="space-y-2">
									<span class="text-sm font-medium text-slate-600">Lipides /100g</span>
									<input id="scan-food-fats" type="number" min="0" step="0.1" class="h-[46px] w-full rounded-[16px] border border-[#cad8e7] px-4 text-slate-700 outline-none focus:border-[#08b37d]" />
								</label>
								<label class="space-y-2">
									<span class="text-sm font-medium text-slate-600">Fibres /100g</span>
									<input id="scan-food-fibers" type="number" min="0" step="0.1" class="h-[46px] w-full rounded-[16px] border border-[#cad8e7] px-4 text-slate-700 outline-none focus:border-[#08b37d]" />
								</label>
								<div class="rounded-[18px] bg-[#eef8ff] px-4 py-4 text-sm leading-6 text-[#46627f] md:col-span-2">
									<p class="font-medium text-[#16223c]">Résumé IA</p>
									<p id="scan-food-summary" class="mt-2">En attente d’analyse.</p>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="flex flex-col-reverse gap-3 border-t border-[#e6eef7] px-5 py-4 md:flex-row md:items-center md:justify-between md:px-6">
					<div class="text-sm text-slate-500">Validation manuelle avant ajout dans la base aliments.</div>
					<div class="flex flex-col gap-3 sm:flex-row">
						<button id="food-scan-analyze" type="button" class="inline-flex min-h-[48px] items-center justify-center rounded-[16px] border border-[#cad8e7] bg-white px-5 py-3 text-[0.96rem] font-medium text-slate-700 transition hover:border-[#08b37d] hover:text-[#08b37d]">Analyser l’image</button>
						<button id="food-scan-save" type="button" class="inline-flex min-h-[48px] items-center justify-center rounded-[16px] bg-[#08b37d] px-5 py-3 text-[0.96rem] font-semibold text-white shadow-[0_16px_36px_rgba(8,179,125,0.2)] transition hover:bg-[#069c6c]">Ajouter à la base aliments</button>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	const authKey = 'nutrivia_auth';
	const foodsError = document.querySelector('#foods-error');
	const foodsSearch = document.querySelector('#foods-search');
	const foodsGrid = document.querySelector('#foods-grid');
	const foodsCount = document.querySelector('#foods-count');
	const foodsEmpty = document.querySelector('#foods-empty');
	const foodsCategories = document.querySelector('#foods-categories');
	const scanTrigger = document.querySelector('#foods-scan-trigger');
	const scanModal = document.querySelector('#food-scan-modal');
	const scanClose = document.querySelector('#food-scan-close');
	const scanInput = document.querySelector('#food-scan-input');
	const scanPick = document.querySelector('#food-scan-pick');
	const scanPreviewWrap = document.querySelector('#food-scan-preview-wrap');
	const scanPreview = document.querySelector('#food-scan-preview');
	const scanAnalyze = document.querySelector('#food-scan-analyze');
	const scanSave = document.querySelector('#food-scan-save');
	const scanStatus = document.querySelector('#food-scan-status');
	const scanLoader = document.querySelector('#food-scan-loader');
	const scanError = document.querySelector('#food-scan-error');
	const scanSummary = document.querySelector('#scan-food-summary');
	const scanName = document.querySelector('#scan-food-name');
	const scanBrand = document.querySelector('#scan-food-brand');
	const scanCategory = document.querySelector('#scan-food-category');
	const scanDescription = document.querySelector('#scan-food-description');
	const scanUnit = document.querySelector('#scan-food-unit');
	const scanConfidence = document.querySelector('#scan-food-confidence');
	const scanCalories = document.querySelector('#scan-food-calories');
	const scanProteins = document.querySelector('#scan-food-proteins');
	const scanCarbs = document.querySelector('#scan-food-carbs');
	const scanFats = document.querySelector('#scan-food-fats');
	const scanFibers = document.querySelector('#scan-food-fibers');

	const categoryMeta = {
		all: { label: 'Tous', icon: 'apple' },
		viande: { label: 'Protéines', icon: 'drumstick' },
		poisson: { label: 'Poissons', icon: 'fish' },
		produit_laitier: { label: 'Produits laitiers', icon: 'bottle' },
		cereale: { label: 'Céréales', icon: 'grain' },
		legume: { label: 'Légumes', icon: 'carrot' },
		fruit: { label: 'Fruits', icon: 'apple' },
		epicerie: { label: 'Épicerie', icon: 'jar' },
		autre: { label: 'Autres', icon: 'dots' },
	};

	let foodsCatalog = [];
	let activeCategory = 'all';
	let currentScanImage = '';
	let currentScanResult = null;

	function getStoredAuth() {
		try {
			const raw = localStorage.getItem(authKey);
			return raw ? JSON.parse(raw) : null;
		} catch {
			return null;
		}
	}

	function setStoredAuth(payload) {
		localStorage.setItem(authKey, JSON.stringify(payload));
	}

	function showError(message) {
		if (!(foodsError instanceof HTMLElement)) return;
		foodsError.textContent = message;
		foodsError.classList.remove('hidden');
	}

	function clearError() {
		if (!(foodsError instanceof HTMLElement)) return;
		foodsError.textContent = '';
		foodsError.classList.add('hidden');
	}

	function showScanError(message) {
		if (!(scanError instanceof HTMLElement)) return;
		scanError.textContent = message;
		scanError.classList.remove('hidden');
	}

	function clearScanError() {
		if (!(scanError instanceof HTMLElement)) return;
		scanError.textContent = '';
		scanError.classList.add('hidden');
	}

	function setScanStatus(message, loading = false) {
		if (scanStatus instanceof HTMLElement) {
			scanStatus.textContent = message;
		}
		scanLoader?.classList.toggle('hidden', !loading);
	}

	function openScanModal() {
		if (!(scanModal instanceof HTMLElement)) return;
		scanModal.classList.remove('hidden', 'pointer-events-none', 'opacity-0');
		scanModal.classList.add('flex', 'opacity-100');
		document.body.classList.add('overflow-hidden');
	}

	function closeScanModal() {
		if (!(scanModal instanceof HTMLElement)) return;
		scanModal.classList.add('hidden', 'pointer-events-none', 'opacity-0');
		scanModal.classList.remove('flex', 'opacity-100');
		document.body.classList.remove('overflow-hidden');
	}

	function resetScanForm() {
		currentScanImage = '';
		currentScanResult = null;
		clearScanError();
		if (scanInput instanceof HTMLInputElement) scanInput.value = '';
		if (scanPreview instanceof HTMLImageElement) scanPreview.src = '';
		scanPreviewWrap?.classList.add('hidden');
		setScanStatus('Importez une image pour lancer l’analyse.', false);
		if (scanSummary instanceof HTMLElement) scanSummary.textContent = 'En attente d’analyse.';
		if (scanName instanceof HTMLInputElement) scanName.value = '';
		if (scanBrand instanceof HTMLInputElement) scanBrand.value = '';
		if (scanCategory instanceof HTMLSelectElement) scanCategory.value = 'autre';
		if (scanDescription instanceof HTMLTextAreaElement) scanDescription.value = '';
		if (scanUnit instanceof HTMLSelectElement) scanUnit.value = 'g';
		if (scanConfidence instanceof HTMLInputElement) scanConfidence.value = '';
		if (scanCalories instanceof HTMLInputElement) scanCalories.value = '';
		if (scanProteins instanceof HTMLInputElement) scanProteins.value = '';
		if (scanCarbs instanceof HTMLInputElement) scanCarbs.value = '';
		if (scanFats instanceof HTMLInputElement) scanFats.value = '';
		if (scanFibers instanceof HTMLInputElement) scanFibers.value = '';
	}

	function fillScanForm(scan) {
		currentScanResult = scan;
		if (scanName instanceof HTMLInputElement) scanName.value = scan.nom ?? '';
		if (scanBrand instanceof HTMLInputElement) scanBrand.value = scan.marque ?? '';
		if (scanCategory instanceof HTMLSelectElement) scanCategory.value = scan.categorie ?? 'autre';
		if (scanDescription instanceof HTMLTextAreaElement) scanDescription.value = scan.description ?? '';
		if (scanUnit instanceof HTMLSelectElement) scanUnit.value = scan.uniteParDefaut ?? 'g';
		if (scanConfidence instanceof HTMLInputElement) scanConfidence.value = `${scan.confiance ?? 0}%`;
		if (scanCalories instanceof HTMLInputElement) scanCalories.value = String(scan.calories100g ?? 0);
		if (scanProteins instanceof HTMLInputElement) scanProteins.value = String(scan.proteines100g ?? 0);
		if (scanCarbs instanceof HTMLInputElement) scanCarbs.value = String(scan.glucides100g ?? 0);
		if (scanFats instanceof HTMLInputElement) scanFats.value = String(scan.lipides100g ?? 0);
		if (scanFibers instanceof HTMLInputElement) scanFibers.value = String(scan.fibres100g ?? 0);
		if (scanSummary instanceof HTMLElement) scanSummary.textContent = scan.resume ?? '';
	}

	function readFileAsDataUrl(file) {
		return new Promise((resolve, reject) => {
			const reader = new FileReader();
			reader.onload = () => resolve(String(reader.result ?? ''));
			reader.onerror = () => reject(new Error("Impossible de lire cette image."));
			reader.readAsDataURL(file);
		});
	}

	async function analyzeCurrentScan() {
		const auth = getStoredAuth();
		if (!auth?.token) {
			window.location.href = '/auth/login';
			return;
		}

		if (!currentScanImage) {
			showScanError('Ajoutez une image avant de lancer l’analyse.');
			return;
		}

		try {
			clearScanError();
			setScanStatus('Analyse du produit en cours...', true);
			scanAnalyze?.setAttribute('disabled', 'disabled');
			const response = await fetch('/app-api/food-scan', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					Authorization: `Bearer ${auth.token}`,
				},
				body: JSON.stringify({
					mode: 'analyze',
					imageDataUrl: currentScanImage,
				}),
			});
			const result = await response.json();
			if (!response.ok) {
				if (response.status === 401) {
					localStorage.removeItem(authKey);
					window.location.href = '/auth/login';
					return;
				}
				throw new Error(result.message || "Impossible d'analyser ce produit.");
			}

			fillScanForm(result.scan);
			setScanStatus('Analyse terminée. Vérifiez la fiche puis enregistrez-la.', false);
		} catch (error) {
			setScanStatus('Analyse indisponible.', false);
			showScanError(error instanceof Error ? error.message : "Impossible d'analyser ce produit.");
		} finally {
			scanAnalyze?.removeAttribute('disabled');
		}
	}

	function buildScanPayload() {
		return {
			nom: scanName instanceof HTMLInputElement ? scanName.value.trim() : '',
			marque: scanBrand instanceof HTMLInputElement ? scanBrand.value.trim() : '',
			categorie: scanCategory instanceof HTMLSelectElement ? scanCategory.value : 'autre',
			description: scanDescription instanceof HTMLTextAreaElement ? scanDescription.value.trim() : '',
			uniteParDefaut: scanUnit instanceof HTMLSelectElement ? scanUnit.value : 'g',
			calories100g: scanCalories instanceof HTMLInputElement ? Number(scanCalories.value || 0) : 0,
			proteines100g: scanProteins instanceof HTMLInputElement ? Number(scanProteins.value || 0) : 0,
			glucides100g: scanCarbs instanceof HTMLInputElement ? Number(scanCarbs.value || 0) : 0,
			lipides100g: scanFats instanceof HTMLInputElement ? Number(scanFats.value || 0) : 0,
			fibres100g: scanFibers instanceof HTMLInputElement ? Number(scanFibers.value || 0) : 0,
		};
	}

	async function saveCurrentScan() {
		const auth = getStoredAuth();
		if (!auth?.token) {
			window.location.href = '/auth/login';
			return;
		}

		const scan = buildScanPayload();
		if (!scan.nom) {
			showScanError("Le nom du produit est requis.");
			return;
		}

		try {
			clearScanError();
			setScanStatus("Enregistrement de l'aliment...", true);
			scanSave?.setAttribute('disabled', 'disabled');
			const response = await fetch('/app-api/food-scan', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					Authorization: `Bearer ${auth.token}`,
				},
				body: JSON.stringify({
					mode: 'save',
					imageDataUrl: currentScanImage,
					scan,
				}),
			});
			const result = await response.json();
			if (!response.ok) {
				if (response.status === 401) {
					localStorage.removeItem(authKey);
					window.location.href = '/auth/login';
					return;
				}
				throw new Error(result.message || "Impossible d'ajouter cet aliment.");
			}

			setStoredAuth({
				...auth,
				token: result.token,
				record: auth.record,
			});
			foodsCatalog = [result.food, ...foodsCatalog].sort((left, right) => left.nom.localeCompare(right.nom, 'fr'));
			renderCategories(foodsCatalog);
			applyFilters();
			setScanStatus('Produit ajouté à la base aliments.', false);
			closeScanModal();
		} catch (error) {
			setScanStatus("Échec de l'enregistrement.", false);
			showScanError(error instanceof Error ? error.message : "Impossible d'ajouter cet aliment.");
		} finally {
			scanSave?.removeAttribute('disabled');
		}
	}

	function escapeHtml(value) {
		return String(value)
			.replaceAll('&', '&amp;')
			.replaceAll('<', '&lt;')
			.replaceAll('>', '&gt;')
			.replaceAll('"', '&quot;')
			.replaceAll("'", '&#39;');
	}

	function formatCount(count) {
		return `${count} aliment${count > 1 ? 's' : ''} trouvé${count > 1 ? 's' : ''}`;
	}

	function formatMacro(value) {
		return Number.isInteger(value) ? String(value) : value.toFixed(1).replace('.0', '');
	}

	function getTip(food) {
		if (food.proteines100g >= 20) {
			return `Excellente source de protéines. ${food.description || 'Idéal pour vos repas riches en protéines.'}`;
		}

		if (food.fibres100g >= 6) {
			return `Riche en fibres. ${food.description || "Parfait pour la satiété et l'équilibre digestif."}`;
		}

		if (food.lipides100g >= 12 && food.categorie === 'fruit') {
			return `Riche en bonnes graisses. ${food.description || 'Excellent pour la satiété.'}`;
		}

		return food.description || 'Bon aliment du quotidien pour varier vos repas.';
	}

	function getCategoryIcon(name) {
		const icons = {
			apple: '<path d="M12 7c.7-2.2 2.4-3.5 4.5-3.5.2 1.8-.5 3.1-1.7 4.1C13.7 8.6 12.9 9 12 9c-3.4 0-6 2.7-6 6 0 3 2.1 5 4.9 5 1.2 0 2.2-.5 3.1-.5.9 0 1.7.5 2.9.5 2.5 0 4.3-2 5.1-4.3-1.6-.4-2.8-1.8-2.8-3.7 0-1.7 1-3.1 2.4-3.7C20.2 6.2 18.3 5 16 5c-1.5 0-2.8.6-4 2Z"/><path d="M13.5 3c-.1 1.2-.8 2.3-1.8 3"/>',
			drumstick: '<path d="M7 14c-1.9-1.9-1.9-5 0-6.9a4.9 4.9 0 0 1 6.9 0l2 2a4.9 4.9 0 0 1 0 6.9c-1.9 1.9-5 1.9-6.9 0l-2-2Z"/><path d="M5.2 15.8 3 18l3 3 2.2-2.2M3.8 16.8l3.4 3.4"/>',
			fish: '<path d="M20 12s-2.5-4-8-4c-2.2 0-4.7 1-7 4 2.3 3 4.8 4 7 4 5.5 0 8-4 8-4Z"/><path d="M8 12h.01M17 9l2-2M17 15l2 2"/>',
			bottle: '<path d="M10 3h4M11 3v4l-3 4v7a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-7l-3-4V3"/>',
			grain: '<path d="M8 18c0-4 2-7 6-10M10 20c0-4.5 2-8 6-11M6 16c0-3.5 1.5-6.5 4.5-9.5"/><path d="M14 10c2 0 4-1 5-3M12 14c2.5 0 4.5-1 6-3M10 18c2.5 0 4.5-1 6-3"/>',
			carrot: '<path d="M9 14c2-2 5.5-5.5 8-8l1 1c-2.5 2.5-6 6-8 8-1.5 1.5-3.5 1.6-5 .1s-1.4-3.5.1-5L9 14Z"/><path d="M15 5V2M18 6l2-2"/>',
			jar: '<path d="M8 4h8M9 4v3l-3 3v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-8l-3-3V4"/><path d="M9 12h6"/>',
			dots: '<path d="M5 12h.01M12 12h.01M19 12h.01"/>',
		};

		return icons[name] ?? icons.dots;
	}

	function renderCategories(foods) {
		if (!(foodsCategories instanceof HTMLElement)) return;

		const availableCategories = ['all', ...new Set(foods.map((food) => food.categorie))];
		foodsCategories.innerHTML = '';

		availableCategories.forEach((category) => {
			const meta = categoryMeta[category] ?? { label: category, icon: 'dots' };
			const button = document.createElement('button');
			button.type = 'button';
			button.dataset.category = category;
			button.className =
				'inline-flex min-h-[42px] items-center gap-2 rounded-[14px] border px-4 py-2.5 text-[0.98rem] font-medium transition';

			if (category === activeCategory) {
				button.classList.add('border-[#53d7ad]', 'bg-[#e8fbf2]', 'text-[#0b8c5f]');
			} else {
				button.classList.add('border-[#d8e2ee]', 'bg-white', 'text-slate-600');
			}

			button.innerHTML = `
				<svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" aria-hidden="true">
					${getCategoryIcon(meta.icon)}
				</svg>
				<span>${escapeHtml(meta.label)}</span>
			`;
			button.addEventListener('click', () => {
				activeCategory = category;
				renderCategories(foodsCatalog);
				applyFilters();
			});
			foodsCategories.appendChild(button);
		});
	}

	function renderFoods(items) {
		if (!(foodsGrid instanceof HTMLElement) || !(foodsCount instanceof HTMLElement) || !(foodsEmpty instanceof HTMLElement)) {
			return;
		}

		foodsCount.textContent = formatCount(items.length);
		foodsEmpty.classList.toggle('hidden', items.length !== 0);
		foodsGrid.innerHTML = '';

		items.forEach((food) => {
			const card = document.createElement('article');
			card.className =
				'overflow-hidden rounded-[22px] border border-[#d8e2ee] bg-white px-5 py-5 shadow-[0_16px_38px_rgba(71,104,145,0.10)]';
			card.innerHTML = `
				<div class="flex items-start justify-between gap-4">
					<div class="min-w-0">
						<h2 class="text-[1.05rem] font-semibold leading-7 text-[#16223c]">${escapeHtml(food.nom)}</h2>
						<p class="mt-1 text-[0.98rem] text-slate-500">Pour 100g</p>
					</div>
					<div class="flex items-start gap-3">
						${food.imageUrl ? `<img src="${escapeHtml(food.imageUrl)}" alt="${escapeHtml(food.nom)}" class="h-[62px] w-[62px] rounded-[18px] object-cover shadow-[0_8px_20px_rgba(71,104,145,0.12)]" />` : ''}
						<div class="text-right">
							<p class="text-[2rem] leading-none font-semibold text-[#08b37d]">${escapeHtml(formatMacro(food.calories100g))}</p>
							<p class="mt-1 text-[0.92rem] text-slate-500">kcal</p>
						</div>
					</div>
				</div>

				<div class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-4">
					<div class="rounded-[16px] bg-[#edf4ff] px-3 py-3 text-center">
						<p class="text-[0.82rem] font-medium text-[#4f7df4]">Protéines</p>
						<p class="mt-1 text-[1.2rem] font-semibold text-[#1d58eb]">${escapeHtml(formatMacro(food.proteines100g))}g</p>
					</div>
					<div class="rounded-[16px] bg-[#fff5ea] px-3 py-3 text-center">
						<p class="text-[0.82rem] font-medium text-[#ff8a2a]">Glucides</p>
						<p class="mt-1 text-[1.2rem] font-semibold text-[#e35a00]">${escapeHtml(formatMacro(food.glucides100g))}g</p>
					</div>
					<div class="rounded-[16px] bg-[#f8efff] px-3 py-3 text-center">
						<p class="text-[0.82rem] font-medium text-[#b66cff]">Lipides</p>
						<p class="mt-1 text-[1.2rem] font-semibold text-[#8527ff]">${escapeHtml(formatMacro(food.lipides100g))}g</p>
					</div>
					<div class="rounded-[16px] bg-[#eaf9f1] px-3 py-3 text-center">
						<p class="text-[0.82rem] font-medium text-[#49b989]">Fibres</p>
						<p class="mt-1 text-[1.2rem] font-semibold text-[#11845b]">${escapeHtml(formatMacro(food.fibres100g))}g</p>
					</div>
				</div>

				<div class="mt-4 flex items-start gap-2 rounded-[14px] bg-slate-50 px-4 py-3 text-[0.95rem] leading-6 text-slate-500">
					<svg viewBox="0 0 24 24" class="mt-0.5 h-4 w-4 shrink-0 text-[#e0b34a]" fill="none" aria-hidden="true">
						<path d="M9 18h6M10 21h4M8.5 14.5c-.9-.8-1.5-2-1.5-3.5a5 5 0 1 1 10 0c0 1.5-.6 2.7-1.5 3.5-.8.7-1.5 1.5-1.5 2.5h-4c0-1-.7-1.8-1.5-2.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
					<span>${escapeHtml(getTip(food))}</span>
				</div>
			`;
			foodsGrid.appendChild(card);
		});
	}

	function applyFilters() {
		if (!(foodsSearch instanceof HTMLInputElement)) return;

		const search = foodsSearch.value.trim().toLowerCase();
		const filtered = foodsCatalog.filter((food) => {
			const matchesCategory = activeCategory === 'all' || food.categorie === activeCategory;
			const matchesSearch =
				!search ||
				food.nom.toLowerCase().includes(search) ||
				food.description.toLowerCase().includes(search) ||
				(categoryMeta[food.categorie]?.label ?? '').toLowerCase().includes(search);
			return matchesCategory && matchesSearch;
		});

		renderFoods(filtered);
	}

	async function loadFoods() {
		const auth = getStoredAuth();
		if (!auth?.token) {
			window.location.href = '/auth/login';
			return;
		}

		const response = await fetch('/app-api/foods', {
			headers: {
				Authorization: `Bearer ${auth.token}`,
			},
		});
		const result = await response.json();

		if (!response.ok) {
			localStorage.removeItem(authKey);
			throw new Error(result.message || 'Impossible de charger les aliments.');
		}

		setStoredAuth({
			...auth,
			token: result.token,
			record: auth.record,
		});

		foodsCatalog = result.foods;
		renderCategories(foodsCatalog);
		applyFilters();
	}

	foodsSearch?.addEventListener('input', applyFilters);
	scanTrigger?.addEventListener('click', () => {
		window.location.href = '/scanner?mode=product&return=/aliments';
	});
	scanClose?.addEventListener('click', closeScanModal);
	scanModal?.addEventListener('click', (event) => {
		if (event.target === scanModal) {
			closeScanModal();
		}
	});
	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') {
			closeScanModal();
		}
	});
	scanPick?.addEventListener('click', () => scanInput?.click());
	scanInput?.addEventListener('change', async () => {
		if (!(scanInput instanceof HTMLInputElement) || !scanInput.files?.[0]) return;
		try {
			clearScanError();
			currentScanImage = await readFileAsDataUrl(scanInput.files[0]);
			if (scanPreview instanceof HTMLImageElement) scanPreview.src = currentScanImage;
			scanPreviewWrap?.classList.remove('hidden');
			setScanStatus('Image prête. Lancez l’analyse.', false);
		} catch (error) {
			showScanError(error instanceof Error ? error.message : "Impossible de charger cette image.");
		}
	});
	scanAnalyze?.addEventListener('click', analyzeCurrentScan);
	scanSave?.addEventListener('click', saveCurrentScan);

	loadFoods()
		.then(clearError)
		.catch((error) => {
			showError(error instanceof Error ? error.message : 'Impossible de charger les aliments.');
		});
</script>

